<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/my_drawer_layout2"
    android:background="@drawable/backai1"
    tools:ignore="HardcodedText"
    tools:context="com.ai.ai_disc.report_page">
    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:layout_height="match_parent"
        android:layout_width="match_parent"
        android:id="@+id/refr">
<ScrollView
    android:layout_width="match_parent"
    android:layout_height="match_parent">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

<androidx.cardview.widget.CardView
    android:layout_width="200dp"
    android:layout_height="wrap_content"
    android:layout_alignParentEnd="true"
    android:layout_marginTop="60dp"
    android:id="@+id/carddetails"
    android:layout_marginRight="15dp"
    app:cardCornerRadius="10dp">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white1"

        android:orientation="vertical">
        <TextView
            android:id="@+id/reportno"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:text="Report No. "
            android:textColor="@color/brown"
            android:textStyle="bold"
            />
        <TextView

            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="left"
            android:layout_marginLeft="5dp"
            android:text="Details:"
            android:textColor="@color/darkblue"
            android:textStyle="bold"
            />

        <LinearLayout
            android:id="@+id/lincrop"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="5dp"

            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"

                android:text="Crop Name"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/cropname"
                android:layout_width="0dp"
                android:textColor="@color/black"
                android:layout_height="wrap_content"
                android:layout_weight="1"

                android:text="CROP" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/lincat"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="5dp"

            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"

                android:text="Category"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/infest"
                android:layout_width="0dp"
                android:textColor="@color/black"
                android:layout_height="wrap_content"
                android:layout_weight="1"

                android:text="CROP" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/lindp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="5dp"

            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"

                android:text="Infestation "
                android:textStyle="bold" />

            <TextView
                android:id="@+id/dpname"
                android:layout_width="0dp"
                android:textColor="@color/black"
                android:layout_height="wrap_content"
                android:layout_weight="1"

                android:text="CROP" />

        </LinearLayout>
        <LinearLayout
            android:id="@+id/linnot"
            android:layout_width="match_parent"

            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_margin="5dp"
                android:layout_weight="1"
                android:justificationMode="inter_word"
                android:text="It is a report for non-crop agricultural incidence"
                android:textStyle="bold" />


        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"

                android:layout_marginTop="5dp"

                android:layout_marginBottom="5dp"
                android:orientation="vertical">
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="10dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="10dp"
                    android:layout_marginTop="10dp"
                    android:layout_marginRight="10dp"
                    android:gravity="left"
                    android:orientation="horizontal">

                    <!--                <androidx.cardview.widget.CardView-->
                    <!--                    android:layout_width="0dp"-->
                    <!--                    android:layout_height="wrap_content"-->
                    <!--                    android:layout_weight="2"-->
                    <!--                    android:backgroundTint="@color/white1"-->
                    <!--                    app:cardCornerRadius="5dp">-->

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="2"

                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:layout_gravity="center"
                            app:srcCompat="@drawable/ic_baseline_person_pin_24" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/username"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginLeft="10dp"

                                android:gravity="left"
                                android:text="Arpan"
                                android:textColor="@color/darkblue"
                                android:textSize="18dp"
                                android:textStyle="bold" />


                            <TextView
                                android:id="@+id/placed"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="left"
                                android:layout_marginLeft="10dp"
                                android:text="date"
                                android:textColor="@color/blue"
                                android:textSize="15dp"
                                android:textStyle="bold" />


                        </LinearLayout>


                    </LinearLayout>
                    <!--                </androidx.cardview.widget.CardView>-->


                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="right"


                        android:orientation="vertical">

                        <ImageView
                            android:id="@+id/showdetails"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:scaleType="fitXY"
                            android:gravity="center"

                            app:srcCompat="@drawable/ic_baseline_receipt_long_24" />


                    </LinearLayout>

                </LinearLayout>


                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="350dp">

                    <LinearLayout
                        android:id="@+id/imagelayout"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"

                        android:orientation="horizontal">

                    </LinearLayout>
                </HorizontalScrollView>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/lininfo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_margin="5dp"
                        android:background="@color/white1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/head"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textStyle="bold"
                            android:text="CROP"
                            android:textColor="@color/heading" />

                        <TextView
                            android:id="@+id/info"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"

                            android:text="CROP"
                            android:textColor="@color/dialogButtonText" />

                    </LinearLayout>
                </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>



                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"

                    app:cardCornerRadius="10dp">



                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"

                        android:orientation="vertical">

                        <androidx.cardview.widget.CardView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"

                            android:layout_marginTop="5dp"

                            app:cardCornerRadius="2dp">

                            <LinearLayout
                                android:id="@+id/croplinfull"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"

                                android:gravity="center"
                                android:orientation="vertical">




                                <LinearLayout
                                    android:id="@+id/lincomment"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_gravity="center"
                                    android:layout_margin="5dp"
                                    android:orientation="vertical">
                                    <LinearLayout
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:orientation="horizontal"
                                        android:layout_marginBottom="5dp">
                                        <TextView
                                            android:id="@+id/previouscomments"
                                            android:layout_width="wrap_content"

                                            android:layout_height="wrap_content"
                                            android:layout_margin="5dp"
                                            android:gravity="left"
                                            android:text="Older"
                                            android:textStyle="bold"
                                            android:textColor="@color/darkblue" />
                                        <TextView
                                            android:id="@+id/nextcomments"
                                            android:layout_width="wrap_content"

                                            android:layout_height="wrap_content"
                                            android:layout_margin="5dp"
                                            android:gravity="right"
                                            android:text="Newer"
                                            android:textStyle="bold"
                                            android:textColor="@color/darkblue" />
                                    </LinearLayout>
                                    <ScrollView
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        >
                                    <LinearLayout
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:orientation="vertical"
                                        android:layout_marginBottom="5dp"
                                        android:id="@+id/lincomm">


                                    </LinearLayout>
                                    </ScrollView>

                                    <LinearLayout
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:orientation="horizontal"

                                        android:weightSum="1">


                                        <LinearLayout
                                            android:layout_width="0dp"
                                            android:layout_height="wrap_content"
                                            android:layout_gravity="center"
                                            android:layout_weight="0.90"

                                            android:orientation="horizontal"
                                            android:padding="0.50sp">

                                            <EditText
                                                android:id="@+id/editText_enterMessage"
                                                android:layout_width="0dp"
                                                android:layout_height="wrap_content"
                                                android:layout_gravity="center"
                                                android:layout_weight="1"
                                                android:background="@drawable/edit_text_border"
                                                android:hint="comment here"
                                                android:inputType="textMultiLine"
                                                android:padding="6dp"
                                                android:text=""
                                                android:textColorHint="@color/black"
                                                android:longClickable="false"
                                                android:textSize="12dp" />


                                            <ImageButton
                                                android:id="@+id/upload"
                                                style="?android:buttonBarButtonStyle"
                                                android:layout_width="wrap_content"
                                                android:layout_height="wrap_content"
                                                android:paddingBottom="5dp"
                                                android:src="@drawable/upload_pic"
                                                android:visibility="gone" />
                                        </LinearLayout>

                                        <LinearLayout
                                            android:layout_width="0dp"
                                            android:layout_height="wrap_content"
                                            android:layout_weight="0.10"
                                            android:baselineAlignBottom="true"
                                            android:gravity="center"
                                            android:paddingBottom="5dp">

                                            <ImageView
                                                android:id="@+id/sendButton"
                                                android:layout_width="wrap_content"
                                                android:layout_height="wrap_content"

                                                android:layout_gravity="center"
                                                android:src="@drawable/send" />

                                        </LinearLayout>

                                    </LinearLayout>


                                </LinearLayout>
                            </LinearLayout>

                        </androidx.cardview.widget.CardView>


                    </LinearLayout>


                </androidx.cardview.widget.CardView>
            </LinearLayout>










        </RelativeLayout>


</ScrollView></androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
    <com.google.android.material.navigation.NavigationView
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:id="@+id/navigation_drawer1"
        app:headerLayout="@layout/header_nav"
        android:layout_gravity="start"
        app:menu="@menu/menutop" />

</androidx.drawerlayout.widget.DrawerLayout>
        app:cardBackgroundColor="@color/white"
        app:cardElevation="10dp"
        android:visibility="gone"
        android:layout_marginTop="5dp"
        android:layout_marginLeft="5dp"
        android:layout_marginRight="5dp"
        android:layout_marginBottom="5dp"
        app:cardCornerRadius="10dp"
        android:id="@+id/cardviewanswer"
        android:layout_height="wrap_content"
        android:layout_width="match_parent">



    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Attachment with solution"
            android:id="@+id/text_view_answer"
            />

        <Button
            android:text="audio solution"
            android:id="@+id/audio_solution"
            android:layout_height="wrap_content"
            android:layout_width="match_parent"/>
        <Button
            android:text="video solution"
            android:id="@+id/video_solution"
            android:layout_height="wrap_content"
            android:layout_width="match_parent"/>
        <Button
            android:text="image solution"
            android:id="@+id/image_solution"
            android:layout_height="wrap_content"
            android:layout_width="match_parent"/>
    </LinearLayout>

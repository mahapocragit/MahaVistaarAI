<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:map="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context="com.ai.ai_disc.reportglobeview"
    app:layout_behavior="@string/appbar_scrolling_view_behavior"
    android:layout_width="match_parent"
    tools:showIn="@layout/layout_globe"
    android:layout_height="match_parent">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"


        android:layout_gravity="center">
<!--        <Button-->
<!--            android:id="@+id/slidebutton"-->
<!--            android:layout_gravity="center"-->
<!--            android:layout_width="150dp"-->
<!--            android:text="filters"-->
<!--            android:layout_height="wrap_content"/>-->
        <fragment
            android:id="@+id/map"
            android:name="com.google.android.gms.maps.SupportMapFragment"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            map:layout_constraintEnd_toEndOf="parent"
            map:layout_constraintStart_toStartOf="parent"
            map:layout_constraintTop_toTopOf="parent" />

        <ProgressBar
            android:id="@+id/progressBar2"
            style="?android:attr/progressBarStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="300dp"
            android:text="loading..."
            map:layout_constraintEnd_toEndOf="parent"
            map:layout_constraintStart_toStartOf="parent"
            map:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
<LinearLayout
    android:layout_width="200dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_gravity="end"
    android:id="@+id/viewslide"
    android:layout_marginRight="10dp"
    android:layout_alignParentTop="true"
    android:layout_alignParentRight="true"
    >
<androidx.cardview.widget.CardView
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="#AB40"
    android:gravity="center_horizontal">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal">
    <TextView
        android:layout_margin="10dp"
        android:id="@+id/textView2r"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:gravity="center"
        android:text="Disease"
        android:layout_weight="1"
        android:textSize="15dp"
        android:textColor="@color/black"
        android:textStyle="bold"/>
    <Switch
        android:layout_weight="1"
        android:id="@+id/switch1"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_margin="10dp"
        android:minWidth="48dp"
        android:minHeight="48dp"
        android:checked="false"
        /></LinearLayout>

</androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/greendark"
        android:gravity="center_horizontal">
<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_horizontal">
        <TextView
            android:layout_margin="10dp"
            android:id="@+id/textView2"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Crop"
            android:textColor="@color/white"
            android:textSize="15dp"
            android:textStyle="bold"/>

        <Spinner
            android:id="@+id/mapcrop"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:minHeight="48dp"
            android:layout_margin="10dp"
            android:layout_weight="1"
            tools:ignore="SpeakableTextPresentCheck" /></LinearLayout></androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:cardBackgroundColor="@color/greendark"
        android:gravity="center_horizontal">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal">
    <TextView
        android:layout_margin="10dp"
            android:id="@+id/textViewt"
            android:layout_width="0dp"
            android:layout_height="match_parent"
        android:layout_weight="1"
            android:text="Affected by"
            android:textStyle="bold"
        android:textColor="@color/white"
            android:textSize="15dp"
            android:gravity="center"/>
        <Spinner
            android:id="@+id/mapdisease"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:minHeight="48dp"
            android:layout_margin="10dp"
            android:layout_weight="1"
            tools:ignore="SpeakableTextPresentCheck" /></LinearLayout></androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:cardBackgroundColor="@color/greendark"
        android:gravity="center_horizontal">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_horizontal">
            <TextView
                android:layout_margin="10dp"
                android:id="@+id/date_upto"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="Period"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:textSize="15dp"
                android:gravity="center"/>
            <Spinner
                android:id="@+id/dateuptospin"
                android:focusable="false"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:minHeight="48dp"
                android:layout_margin="10dp"
                android:layout_weight="1"
                tools:ignore="SpeakableTextPresentCheck" /></LinearLayout></androidx.cardview.widget.CardView>
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:id="@+id/carddate"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/greendark"
        android:gravity="center_horizontal">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">
            <TextView
                android:layout_margin="5dp"
                android:id="@+id/date_start"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Set Starting Date"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:textSize="15dp"
                android:minHeight="48dp"
                android:gravity="center"/>
            <TextView
                android:layout_margin="5dp"
                android:id="@+id/date_end"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Set Ending Date"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:textSize="15dp"
                android:minHeight="48dp"
                android:gravity="center"/>
            </LinearLayout></androidx.cardview.widget.CardView>

</LinearLayout>


</RelativeLayout>
<?xml version="1.0" encoding="utf-8"?>
<!--XML implementation of Card Layout-->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_gravity="center"
    android:layout_margin="5dp"

    app:cardCornerRadius="5dp"
    app:cardElevation="5dp">
<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">
    <ImageView
        android:id="@+id/croppic"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_gravity="center_horizontal">

    </ImageView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:layout_marginBottom="5dp"
            android:layout_marginLeft="5dp"
            android:layout_marginRight="5dp"
            android:layout_weight="1"
            android:orientation="vertical"
            >

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_horizontal">


                <TextView

                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:text="Report ID"
                    android:layout_weight="1"
                    android:gravity="center_vertical"
                    />
                <TextView
                    android:id="@+id/reportid"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:text="TextView"
                    android:layout_weight="1"
                    android:gravity="center_horizontal"/></LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"

                android:gravity="center_horizontal">


                <TextView

                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:text="Crop"
                    android:gravity="center_vertical"
                    android:layout_weight="1"
                    />
                <TextView
                    android:id="@+id/cropnamereport"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:text="TextView"
                    android:layout_weight="1"
                    android:gravity="center_horizontal"/></LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"

                android:gravity="center_horizontal">


                <TextView

                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:text="Date"
                    android:layout_weight="1"
                    android:gravity="center_vertical"
                    />
                <TextView
                    android:id="@+id/datereport"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:text="TextView"
                    android:layout_weight="1"
                    android:gravity="center_horizontal"/></LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"

                android:gravity="center_horizontal">


                <TextView

                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:text="Images"
                    android:gravity="center_vertical"
                    android:layout_weight="1"
                    />
                <TextView
                    android:id="@+id/numbofimages"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:text="TextView"
                    android:layout_weight="1"
                    android:gravity="center_horizontal"/></LinearLayout>






        </LinearLayout>


        <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="5dp"
        android:layout_marginBottom="5dp"
        android:layout_marginLeft="5dp"
        android:layout_marginRight="5dp"
            android:layout_weight="1"
        android:orientation="vertical"
        >

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"

            android:gravity="center_horizontal">


            <TextView

                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:text="Report Type"
                android:gravity="center_vertical"
                android:layout_weight="1"
                />
            <TextView
                android:id="@+id/dptype"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:text="TextView"
                android:layout_weight="1"
                android:gravity="center_horizontal"/></LinearLayout>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"

            android:gravity="center_horizontal">


            <TextView

                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:text="Occurrence"
                android:gravity="center_vertical"
                android:layout_weight="1"
                />
            <TextView
                android:id="@+id/dpname"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:text="TextView"
                android:layout_weight="1"
                android:gravity="center_horizontal"/></LinearLayout>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"

            android:gravity="center_horizontal">


            <TextView

                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:text="Locality"
                android:layout_weight="1"
                android:gravity="center_vertical"
                />
            <TextView
                android:id="@+id/area"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:text="TextView"
                android:layout_weight="1"
                android:gravity="center_horizontal"/></LinearLayout>





        <TextView

            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            />

    </LinearLayout>


    </LinearLayout>


    <com.google.android.material.button.MaterialButton
    android:id="@+id/uploadreportimage"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:text="Make New Report">
</com.google.android.material.button.MaterialButton>
</LinearLayout>


</androidx.cardview.widget.CardView>

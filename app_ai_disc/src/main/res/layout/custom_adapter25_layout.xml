                <TextView
                    android:id="@+id/date_sowing_value"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:layout_weight="50"
                    android:text="DATE SOWING value " />

            </LinearLayout>

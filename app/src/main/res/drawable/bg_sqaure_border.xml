<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Border color -->
    <stroke
        android:width="1dp"
        android:color="@color/badge_bg"/>

    <!-- Background color -->
    <solid
        android:color="@color/app_bg"/>

    <!-- Square corners (no radius) -->
    <corners android:radius="0dp"/>

    <!-- Optional inner padding -->
    <padding
        android:left="2dp"
        android:top="2dp"
        android:right="2dp"
        android:bottom="2dp"/>

</shape>
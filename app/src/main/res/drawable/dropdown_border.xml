<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Rounded corners for smooth edges -->
    <corners android:radius="12dp" />

    <!-- Soft gradient background -->
    <gradient
        android:startColor="#FFFFFFFF"
        android:endColor="#E6E2E2"
        android:angle="270" />

    <!-- Subtle border with a professional accent color -->
    <stroke
        android:width="1.5dp"
        android:color="#0D91CD" />

    <!-- Inner padding -->
    <padding
        android:left="10dp"
        android:top="8dp"
        android:right="10dp"
        android:bottom="8dp" />

    <!-- Soft shadow glow (for modern look on Lollipop+) -->
    <size
        android:width="0dp"
        android:height="0dp" />
</shape>

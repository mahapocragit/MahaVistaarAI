<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Solid white fill for the background of the image area -->
    <solid android:color="#FFFFFF" />

    <!-- Dotted stroke/border configuration -->
    <stroke
        android:width="2dp"
        android:color="#B0B0B0"
        android:dashWidth="10dp"
        android:dashGap="10dp" />

    <!-- Rounded corners for the box -->
    <corners android:radius="12dp" />

    <!-- Optional padding if needed inside the drawable, though padding is usually set on the View -->
     <padding
        android:left="10dp"
        android:top="10dp"
        android:right="10dp"
        android:bottom="10dp" />

</shape>
<resources xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Base application theme. -->
    <style name="Theme.FarmerApp" parent="Theme.MaterialComponents.Light.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/status_green</item>
        <item name="colorPrimaryVariant">@color/actionbar_color_figma</item>
        <!--        <item name="colorPrimaryVariant">@color/light_green</item>-->
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Customize your theme here. -->
        <item name="android:statusBarColor">@color/actionbar_color_figma</item>
        <item name="android:fontFamily">@font/poppins_regular_font</item>
        <item name="fontFamily">@font/poppins_regular_font</item>
    </style>

    <style name="OtpBoxStyle">
        <item name="android:layout_width">40dp</item>
        <item name="android:layout_height">45dp</item>
        <item name="android:layout_margin">6dp</item>
        <item name="android:gravity">center</item>
        <item name="android:textSize">16sp</item>
        <item name="android:inputType">number</item>
        <item name="android:maxLength">1</item>
        <item name="android:background">@drawable/otp_box_bg</item>
    </style>

    <!-- Style for the name of the detected pest/disease -->
    <style name="PestResultText" parent="android:Widget.TextView">
        <!-- Text size is slightly larger for visibility -->
        <item name="android:textSize">16sp</item>
        <!-- Dark text color -->
        <item name="android:textColor">#333333</item>
        <!-- Bold style for emphasis on the name -->
        <item name="android:textStyle">bold</item>
        <!-- Padding for the icon next to the text -->
        <item name="android:drawablePadding">12dp</item>
    </style>

    <style name="Theme.FarmerApp.NoActionBar">
        <item name="colorPrimary">@color/actionbar_color_figma</item>
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:fontFamily">@font/poppins_regular_font</item>
        <item name="fontFamily">@font/poppins_regular_font</item>
        <item name="android:statusBarColor">@color/actionbar_color_figma</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <style name="Theme.FarmerApp.AppBarOverlay" parent="ThemeOverlay.AppCompat.Dark.ActionBar">
        <item name="android:fontFamily">@font/poppins_regular_font</item>
        <item name="fontFamily">@font/poppins_regular_font</item>
    </style>

    <style name="Theme.FarmerApp.PopupOverlay" parent="ThemeOverlay.AppCompat.Light">
        <item name="android:fontFamily">@font/poppins_regular_font</item>
        <item name="fontFamily">@font/poppins_regular_font</item>
    </style>
</resources>
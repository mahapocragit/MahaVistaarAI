<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Base application theme. -->
    <style name="AppTheme" parent="Theme.AppCompat.Light.NoActionBar">
        <!-- Customize your theme here. -->
        <item name="android:statusBarColor" tools:ignore="NewApi">@color/actionbar_color_figma</item>
        <item name="android:fontFamily">@font/poppins_regular_font</item>
        <item name="fontFamily">@font/poppins_regular_font</item>
    </style>

    <style name="WeatherTheme" parent="Theme.AppCompat.Light.NoActionBar">
        <!-- Customize your theme here. -->
        <item name="android:statusBarColor" tools:ignore="NewApi">@color/gradient_top_figma</item>
        <item name="android:fontFamily">@font/poppins_regular_font</item>
        <item name="fontFamily">@font/poppins_regular_font</item>
    </style>

    <style name="AppTheme.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:fontFamily">@font/poppins_regular_font</item>
        <item name="fontFamily">@font/poppins_regular_font</item>
    </style>
    <style name="RadioButtonStyle" parent="AppTheme">
        <item name="colorControlNormal">@color/status_red</item>
        <item name="colorAccent">@color/schedule_up</item>
        <item name="android:textColorSecondary">@color/black</item>
    </style>

    <style name="AppTheme.AppBarOverlay" parent="ThemeOverlay.AppCompat.Dark.ActionBar">
        <item name="drawerArrowStyle">@style/DrawerArrowStyle</item>
        <item name="android:fontFamily">@font/poppins_regular_font</item>
        <item name="fontFamily">@font/poppins_regular_font</item>
    </style>

    <style name="AppTheme.PopupOverlay" parent="ThemeOverlay.AppCompat.Light">
        <item name="android:fontFamily">@font/poppins_regular_font</item>
        <item name="fontFamily">@font/poppins_regular_font</item>
    </style>

    <style name="MyTheme" parent="@android:style/Theme.Holo.Light">
        <item name="android:actionBarStyle">@style/MyActionBar</item>
        <item name="android:fontFamily">@font/poppins_regular_font</item>
        <item name="fontFamily">@font/poppins_regular_font</item>
    </style>

    <style name="MyActionBar" parent="@android:style/Widget.Holo.Light.ActionBar">
        <item name="android:background">@color/transparent_green</item>
        <item name="android:fontFamily">@font/poppins_regular_font</item>
        <item name="fontFamily">@font/poppins_regular_font</item>
    </style>


    <style name="AppProgressBar" parent="@style/Widget.AppCompat.ProgressBar">
        <item name="android:indeterminateTint" tools:ignore="NewApi">@color/status_red</item>
        <item name="android:fontFamily">@font/poppins_regular_font</item>
        <item name="fontFamily">@font/poppins_regular_font</item>
    </style>

    <style name="TextLabel" parent="TextAppearance.Design.Hint">
        <item name="android:textSize">16sp</item>
        <item name="android:fontFamily">@font/poppins_regular_font</item>
        <item name="fontFamily">@font/poppins_regular_font</item>
    </style>
    <style name="DrawerArrowStyle" parent="Widget.AppCompat.DrawerArrowToggle">
        <item name="color">@color/status_green</item>
        <item name="android:fontFamily">@font/poppins_regular_font</item>
        <item name="fontFamily">@font/poppins_regular_font</item>
    </style>

    <style name="AppThemeActionbar" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="android:actionBarSize">15dp</item>
        <item name="android:fontFamily">@font/poppins_regular_font</item>
        <item name="fontFamily">@font/poppins_regular_font</item>
    </style>

    <style name="CustomMaterialDatePickerTheme" parent="ThemeOverlay.MaterialComponents.MaterialCalendar">
        <!-- 🎨 Primary color for selection and header -->
        <item name="colorPrimary">@color/actionbar_color_figma</item>
        <item name="colorOnPrimary">@android:color/white</item>

        <!-- 📅 Background and header -->
        <item name="materialCalendarStyle">@style/CustomCalendarStyle</item>
        <item name="materialCalendarHeaderTitle">@style/CustomCalendarHeaderTitle</item>

        <!-- ✨ Animation and surface color (optional) -->
        <item name="android:windowAnimationStyle">@style/CalendarAnimation</item>
        <item name="colorSurface">@android:color/white</item>
    </style>

    <!-- Smaller date cell radius, compact look -->
    <style name="CustomCalendarStyle" parent="Widget.MaterialComponents.MaterialCalendar">
        <item name="android:radius">12dp</item>
    </style>

    <!-- 🏷️ Header title customization -->
    <style name="CustomCalendarHeaderTitle" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textSize">20sp</item> <!-- ⬆️ Increased title size -->
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <!-- Optional fade animation -->
    <style name="CalendarAnimation">
        <item name="android:windowEnterAnimation">@android:anim/fade_in</item>
        <item name="android:windowExitAnimation">@android:anim/fade_out</item>
    </style>
    <!-- res/values/styles.xml -->
    <style name="ToolbarTitleStyle">
        <item name="android:textSize">16dp</item>
        <item name="android:textColor">@android:color/white</item>
        <item name="android:textStyle">bold</item>
    </style>
</resources>

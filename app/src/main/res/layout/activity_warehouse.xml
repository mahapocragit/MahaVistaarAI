        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/height20"
            android:layout_marginStart="@dimen/padding20"
            android:background="@color/white_dim_light"
            android:padding="15dp"
            android:elevation="@dimen/height5"
            android:layout_marginEnd="@dimen/padding20">

            <TextView
                android:id="@+id/textTotalWarehouse"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:layout_marginLeft="40dp"
                android:textColor="@color/status_green"
                android:textStyle="bold"
                android:text="@string/total_warehouse">

            </TextView>
            <TextView
                android:id="@+id/textAvailableCapacity"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/total_available_capacity"
                android:layout_marginTop="@dimen/text8"
                android:textSize="@dimen/text12"
                android:layout_marginLeft="40dp"
                android:textColor="@color/status_green"
                android:textStyle="bold"
                android:layout_below="@+id/textTotalWarehouse">
            </TextView>
        </RelativeLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/height5"
            android:layout_marginLeft="@dimen/height5"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_ware_house_name"
                android:layout_width="@dimen/height140"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/padding1"
                android:background="@color/status_green"
                android:gravity="center"
                android:padding="5dp"
                android:text="@string/warehouse_details"
                android:textColor="@color/white"
                android:textSize="10sp"
                android:textStyle="bold" />


            <TextView
                android:id="@+id/tv_Total_available_Capacity"
                android:layout_width="@dimen/height160"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/padding1"
                android:background="@color/status_green"
                android:gravity="center"
                android:padding="5dp"
                android:text="@string/total_available_capacity"
                android:textColor="@color/white"
                android:textSize="10sp"
                android:textStyle="bold" />


            <TextView
                android:id="@+id/tv_record_date"
                android:layout_width="@dimen/height100"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/padding1"
                android:background="@color/status_green"
                android:gravity="center"
                android:padding="5dp"
                android:text="@string/record_date"
                android:textColor="@color/white"
                android:textSize="10sp"
                android:textStyle="bold" />

        </LinearLayout>

        <androidx.core.widget.NestedScrollView
            android:id="@+id/scrollView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="5dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/rl_toolbar">

        <HorizontalScrollView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="@dimen/height5"
            >


            <TextView
                android:id="@+id/wareHouseEmptyTextView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone"
                android:padding="8dp"
                android:textStyle="normal"
                android:gravity="center"
                android:text="Data Not Available"
                android:textColor="@color/text_black_light" />

            <androidx.core.widget.NestedScrollView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:overScrollMode="never">


                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/wareHousereport"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:scrollbarAlwaysDrawHorizontalTrack="true"
                    android:scrollbarStyle="insideOverlay"
                    android:scrollbars="horizontal">

                </androidx.recyclerview.widget.RecyclerView>
            </androidx.core.widget.NestedScrollView>
        </LinearLayout>



        </HorizontalScrollView>
        </androidx.core.widget.NestedScrollView>

    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
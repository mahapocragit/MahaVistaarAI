<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".activity.Warehouse">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">
    <include
        android:id="@+id/relativeLayoutTopBar"
        layout="@layout/layout_toolbar" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/source_info_warehouse"
            android:textSize="16sp"
            android:layout_marginTop="5dp"
            android:gravity="center_horizontal"
            android:textColor="@color/gray_light">
        </TextView>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/height45"
        android:layout_marginTop="10dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/textViewDistrict"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginStart="@dimen/padding20"
            android:layout_marginEnd="@dimen/padding20"
            android:background="@drawable/layout_warehouse_dropdown"
            android:gravity="center"
            android:text="@string/farmer_select_district"
            android:hint="@string/farmer_select_district"
            android:paddingStart="@dimen/padding20"
            android:paddingEnd="@dimen/padding20"
            android:textColor="@color/heading"
            android:textSize="@dimen/text14"
            android:textStyle="normal" />

        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:layout_marginEnd="@dimen/padding30"
            android:contentDescription="@string/app_name"
            app:srcCompat="@drawable/ic_baseline_arrow_drop_down_24"
            tools:ignore="VectorDrawableCompat"
            android:layout_marginRight="@dimen/padding30"
            android:layout_alignParentRight="true" />
    </RelativeLayout>

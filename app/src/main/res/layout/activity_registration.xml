            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/height5"
                android:elevation="8dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/textViewTaluka"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:background="@drawable/drop_down"
                    android:gravity="start|center"
                    android:hint="@string/farmer_select_taluka"
                    android:layout_marginLeft="20dp"
                    android:layout_marginRight="20dp"
                    android:layout_marginTop="10dp"
                    android:textColorHint="@color/text_black"
                    android:paddingEnd="@dimen/padding20"
                    android:paddingStart="@dimen/padding20"
                    android:textColor="@color/heading"
                    android:textSize="@dimen/text14"
                    android:textStyle="normal" />

                <ImageView
                    android:id="@+id/imageviewTaluka"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:layout_marginEnd="@dimen/padding30"
                    android:contentDescription="@string/app_name"
                    app:srcCompat="@drawable/ic_expand_more_black_24dp"
                    tools:ignore="VectorDrawableCompat"
                    android:layout_alignParentRight="true"
                    android:layout_marginRight="@dimen/padding30"
                    app:tint="@color/gray" />

            </RelativeLayout>

            <!--            <TextView-->
            <!--                android:layout_width="match_parent"-->
            <!--                android:layout_height="wrap_content"-->
            <!--                android:layout_marginTop="@dimen/padding10"-->
            <!--                android:gravity="start|center"-->
            <!--                android:paddingEnd="@dimen/padding20"-->
            <!--                android:paddingStart="@dimen/padding20"-->
            <!--                android:text="Village"-->
            <!--                android:textColor="@color/heading"-->
            <!--                android:textSize="@dimen/text16"-->
            <!--                android:textStyle="bold" />-->

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:elevation="8dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/textViewVillage"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:background="@drawable/drop_down"
                    android:gravity="start|center"
                    android:hint="@string/farmer_select_village"
                    android:layout_marginLeft="20dp"
                    android:layout_marginRight="20dp"
                    android:layout_marginTop="15dp"
                    android:textColorHint="@color/text_black"
                    android:paddingEnd="@dimen/padding20"
                    android:paddingStart="@dimen/padding20"
                    android:textColor="@color/heading"
                    android:textSize="@dimen/text14"
                    android:textStyle="normal" />

                <ImageView
                    android:id="@+id/imageviewVillage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:layout_marginEnd="@dimen/padding30"
                    android:contentDescription="@string/app_name"
                    app:srcCompat="@drawable/ic_expand_more_black_24dp"
                    tools:ignore="VectorDrawableCompat"
                    android:layout_alignParentRight="true"
                    android:layout_marginRight="@dimen/padding30"
                    app:tint="@color/gray" />

            </RelativeLayout>
            <Button
                android:id="@+id/submitButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_margin="30dp"
                android:padding="@dimen/padding12"
                android:backgroundTint="@color/light_green"
                android:text="@string/reg_submit"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="@dimen/text16" />
        </LinearLayout>
    </LinearLayout>
    </ScrollView>
</LinearLayout>


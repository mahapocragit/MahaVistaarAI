<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bottom_bg_color"
    tools:context=".activity.Registration">
    <ScrollView
        xmlns:android="http://schemas.android.com/apk/res/android"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_margin="20dp"
        android:elevation="@dimen/height5"
        android:gravity="center"
        android:background="@color/transparent_green"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/imageViewProfile"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:layout_marginTop="10dp"
            android:src="@drawable/img_registration">
        </ImageView>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="@dimen/text20"
            android:visibility="gone"
            android:layout_marginTop="15dp"
            android:textColor="@color/status_green"
            android:text="Add Profile Picture">
        </TextView>

        <EditText
            android:id="@+id/nameEditText"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:background="@drawable/login_edit_bg"
            android:digits="@string/name_validation"
            android:gravity="center|start"
            android:hint="@string/reg_name"
            android:inputType="text"
            android:elevation="8dp"
            android:layout_marginLeft="20dp"
            android:layout_marginRight="20dp"
            android:layout_marginTop="10dp"
            android:maxLines="1"
            android:maxLength="30"
            android:textSize="@dimen/text12"
            android:textColor="@color/black"
            android:textColorHint="@color/text_black"
            android:paddingStart="@dimen/padding20"
            android:paddingEnd="@dimen/padding20" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:weightSum="2"
            android:orientation="horizontal">
            <EditText
                android:id="@+id/mobNoEditText"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:background="@drawable/login_edit_bg"
                android:digits="@string/numeric"
                android:gravity="center|start"
                android:elevation="8dp"
                android:layout_marginLeft="20dp"
                android:layout_marginRight="20dp"
                android:textSize="@dimen/text12"
                android:layout_weight="0.5"
                android:hint="@string/reg_mobno"
                android:textColor="@color/black"
                android:textColorHint="@color/text_black"
                android:inputType="number"
                android:maxLength="10"
                android:maxLines="1"
                android:paddingStart="@dimen/padding20"
                android:paddingEnd="@dimen/padding20" />

            <TextView
                android:id="@+id/textViewVerify"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="2dp"
                android:paddingLeft="5dp"
                android:textSize="@dimen/text14"
                android:background="@drawable/btn_bg"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:layout_marginRight="@dimen/height20"
                android:gravity="center"
                android:layout_weight="1.5"
                android:text="@string/reg_verify">

            </TextView>
        </LinearLayout>

        <EditText
            android:id="@+id/emailId"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:background="@drawable/login_edit_bg"
            android:gravity="center|start"
            android:hint="@string/reg_email"
            android:textColorHint="@color/text_black"
            android:inputType="text"
            android:elevation="8dp"
            android:layout_marginLeft="20dp"
            android:layout_marginRight="20dp"
            android:textSize="@dimen/text12"
            android:maxLines="1"
            android:paddingStart="@dimen/padding20"
            android:textColor="@color/black"
            android:paddingEnd="@dimen/padding20" />

        <EditText
            android:id="@+id/passwordEditText"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:background="@drawable/login_edit_bg"
            android:gravity="center|start"
            android:hint="@string/reg_pwd"
            android:textColorHint="@color/text_black"
            android:inputType="textPassword"
            android:elevation="8dp"
            android:layout_marginLeft="20dp"
            android:layout_marginRight="20dp"
            android:textSize="@dimen/text12"
            android:maxLines="1"
            android:paddingStart="@dimen/padding20"
            android:paddingEnd="@dimen/padding20" />
        <EditText
            android:id="@+id/confirmPasswordEditText"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:background="@drawable/login_edit_bg"
            android:gravity="center|start"
            android:hint="@string/confirm_password"
            android:textColorHint="@color/text_black"
            android:inputType="textPassword"
            android:elevation="8dp"
            android:layout_marginLeft="20dp"
            android:layout_marginRight="20dp"
            android:textSize="@dimen/text12"
            android:maxLines="1"
            android:paddingStart="@dimen/padding20"
            android:paddingEnd="@dimen/padding20" />


        <!--        <com.google.android.material.textfield.TextInputLayout-->

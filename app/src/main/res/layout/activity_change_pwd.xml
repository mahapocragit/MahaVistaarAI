<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    tools:context=".activity.ConfirmPassword">
    <include
        android:id="@+id/relativeLayoutTopBar"
        layout="@layout/layout_toolbar" />
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="20dp"
        android:padding="10dp"
        app:cardBackgroundColor="@color/transparent_green"
        app:cardCornerRadius="5dp"
        app:cardElevation="5dp">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/padding30"
        android:layout_marginRight="@dimen/padding30"
        android:orientation="vertical">

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/newPasswordTextInput"
            android:layout_width="match_parent"
            android:layout_height="@dimen/height70"
            android:layout_marginLeft="@dimen/padding15"
            android:layout_marginRight="@dimen/padding15"
            android:layout_marginTop="@dimen/padding5"
            android:elevation="8dp"
            android:textColorHint="@color/text_black"
            app:passwordToggleEnabled="true"
            app:hintTextAppearance="@style/TextLabel"
            app:passwordToggleTint="@color/status_green">

            <EditText
                android:id="@+id/newPasswordEditText"
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:background="@drawable/login_edit_bg"
                android:gravity="center|start"
                android:hint="@string/new_password"
                android:inputType="textWebPassword"
                android:maxLines="1"
                android:maxLength="20"
                android:paddingEnd="@dimen/padding20"
                android:paddingStart="@dimen/padding20"
                android:textAllCaps="false"
                android:longClickable="false"
                android:textIsSelectable="false"
                />

        </com.google.android.material.textfield.TextInputLayout>
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/passwordTextInput"
            android:layout_width="match_parent"
            android:layout_height="@dimen/height70"
            android:layout_marginLeft="@dimen/padding15"
            android:layout_marginRight="@dimen/padding15"
            android:layout_marginTop="@dimen/padding5"
            android:elevation="8dp"
            android:textColorHint="@color/text_black"
            app:passwordToggleEnabled="true"
            app:hintTextAppearance="@style/TextLabel"
            app:passwordToggleTint="@color/status_green">

            <EditText
                android:id="@+id/confirmPasswordEditText"
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:background="@drawable/login_edit_bg"
                android:gravity="center|start"
                android:hint="@string/confirm_password"
                android:inputType="textWebPassword"
                android:maxLines="1"
                android:maxLength="20"
                android:paddingEnd="@dimen/padding20"
                android:paddingStart="@dimen/padding20"
                android:textAllCaps="false"
                android:longClickable="false"
                android:textIsSelectable="false" />

        </com.google.android.material.textfield.TextInputLayout>

        <Button
            android:id="@+id/submitButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="@dimen/padding20"
            android:layout_marginLeft="@dimen/padding30"
            android:layout_marginRight="@dimen/padding30"
            android:layout_marginTop="@dimen/padding10"
            android:background="@color/purple_200"
            android:padding="@dimen/padding10"
            android:text="Submit"
            android:textAllCaps="true"
            android:textColor="@color/white"
            android:textSize="@dimen/text16" />

    </LinearLayout>
    </androidx.cardview.widget.CardView>
</LinearLayout>
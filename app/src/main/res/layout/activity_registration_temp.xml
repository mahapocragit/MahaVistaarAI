<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/actionbar_color_figma"
    tools:context=".ui.screens.authentication.Registration">

    <ImageView
        android:id="@+id/backPressIcon"
        android:layout_width="45dp"
        android:layout_height="@dimen/_40sdp"
        android:layout_marginStart="@dimen/_8sdp"
        android:layout_marginTop="@dimen/_10sdp"
        android:padding="@dimen/_5sdp"
        android:rotation="90"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/down_arrow_figma"
        app:tint="@color/white" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/_10sdp"
        android:orientation="vertical"
        app:layout_constraintBottom_toTopOf="@+id/imageView15"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:id="@+id/textView5"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="Register"
            android:textColor="@color/white"
            android:textSize="@dimen/_22sdp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textView6"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="Your Account!"
            android:textColor="@color/white"
            android:textSize="@dimen/_22sdp"
            android:textStyle="bold" />


    </LinearLayout>

    <com.mikhaellopez.circularimageview.CircularImageView
        android:id="@+id/imageView15"
        android:layout_width="@dimen/_100sdp"
        android:layout_height="@dimen/_100sdp"
        android:elevation="10dp"
        android:src="@drawable/pocra_latest_logo"
        app:layout_constraintBottom_toTopOf="@+id/cardView2"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/cardView2" />

    <androidx.cardview.widget.CardView
        android:id="@+id/cardView2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="@dimen/_500sdp"
        android:layout_marginBottom="-10dp"
        app:cardCornerRadius="@dimen/_15sdp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="@dimen/_40sdp"
                android:layout_marginBottom="@dimen/_20sdp"
                android:elevation="@dimen/height5"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="15dp"
                    android:text="Add Profile Picture"
                    android:textColor="@color/status_green"
                    android:textSize="@dimen/text20"
                    android:visibility="gone" />

                <EditText
                    android:id="@+id/nameEditText"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_marginLeft="20dp"
                    android:layout_marginTop="10dp"
                    android:layout_marginRight="20dp"
                    android:background="@drawable/login_edit_bg"
                    android:digits="@string/name_validation"
                    android:elevation="8dp"
                    android:gravity="center|start"
                    android:hint="@string/reg_name"
                    android:inputType="text"
                    android:maxLength="30"
                    android:maxLines="1"
                    android:paddingStart="@dimen/padding20"
                    android:paddingEnd="@dimen/padding20"
                    android:textColor="@color/black"
                    android:textColorHint="@color/text_black"
                    android:textSize="@dimen/text12" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="2">

                    <EditText
                        android:id="@+id/mobNoEditText"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:layout_marginLeft="20dp"
                        android:layout_marginRight="20dp"
                        android:layout_weight="0.5"
                        android:background="@drawable/login_edit_bg"
                        android:digits="@string/numeric"
                        android:elevation="8dp"
                        android:gravity="center|start"
                        android:hint="@string/reg_mobno"
                        android:inputType="number"
                        android:maxLength="10"
                        android:maxLines="1"
                        android:paddingStart="@dimen/padding20"
                        android:paddingEnd="@dimen/padding20"
                        android:textColor="@color/black"
                        android:textColorHint="@color/text_black"
                        android:textSize="@dimen/text12" />

                    <TextView
                        android:id="@+id/textViewVerify"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="2dp"
                        android:layout_marginRight="@dimen/height20"
                        android:layout_weight="1.5"
                        android:background="@drawable/btn_bg"
                        android:gravity="center"
                        android:paddingLeft="5dp"
                        android:text="@string/reg_verify"
                        android:textColor="@color/white"
                        android:textSize="@dimen/text14"
                        android:textStyle="bold">

                    </TextView>
                </LinearLayout>

                <EditText
                    android:id="@+id/emailId"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_marginLeft="20dp"
                    android:layout_marginRight="20dp"
                    android:background="@drawable/login_edit_bg"
                    android:elevation="8dp"
                    android:gravity="center|start"
                    android:hint="@string/reg_email"
                    android:inputType="text"
                    android:maxLines="1"
                    android:paddingStart="@dimen/padding20"
                    android:paddingEnd="@dimen/padding20"
                    android:textColor="@color/black"
                    android:textColorHint="@color/text_black"
                    android:textSize="@dimen/text12"
                    android:visibility="gone" />

                <EditText
                    android:id="@+id/passwordEditText"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_marginLeft="20dp"
                    android:layout_marginRight="20dp"
                    android:background="@drawable/login_edit_bg"
                    android:elevation="8dp"
                    android:gravity="center|start"
                    android:hint="@string/reg_pwd"
                    android:inputType="textPassword"
                    android:maxLines="1"
                    android:paddingStart="@dimen/padding20"
                    android:paddingEnd="@dimen/padding20"
                    android:textColorHint="@color/text_black"
                    android:textSize="@dimen/text12" />

                <EditText
                    android:id="@+id/confirmPasswordEditText"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_marginLeft="20dp"
                    android:layout_marginRight="20dp"
                    android:background="@drawable/login_edit_bg"
                    android:elevation="8dp"
                    android:gravity="center|start"
                    android:hint="@string/confirm_password"
                    android:inputType="textPassword"
                    android:maxLines="1"
                    android:paddingStart="@dimen/padding20"
                    android:paddingEnd="@dimen/padding20"
                    android:textColorHint="@color/text_black"
                    android:textSize="@dimen/text12" />


                <!--        <com.google.android.material.textfield.TextInputLayout-->
                <!--            android:layout_width="match_parent"-->
                <!--            android:layout_height="wrap_content"-->
                <!--            android:layout_marginLeft="@dimen/padding15"-->
                <!--            android:layout_marginTop="@dimen/padding10"-->
                <!--            android:layout_marginRight="@dimen/padding15"-->
                <!--            android:textColorHint="@color/text_black"-->
                <!--            app:hintTextAppearance="@style/TextLabel">-->

                <!--            <EditText-->
                <!--                android:id="@+id/mNameEditText"-->
                <!--                android:layout_width="match_parent"-->
                <!--                android:layout_height="70dp"-->
                <!--                android:background="@drawable/login_edit_bg"-->
                <!--                android:gravity="center|start"-->
                <!--                android:hint="Enter Your Email ID"-->
                <!--                android:inputType="text"-->
                <!--                android:maxLines="1"-->
                <!--                android:paddingStart="@dimen/padding20"-->
                <!--                android:paddingEnd="@dimen/padding20" />-->

                <!--        </com.google.android.material.textfield.TextInputLayout>-->

                <!--        <TextView-->
                <!--            android:layout_width="wrap_content"-->
                <!--            android:layout_height="wrap_content"-->
                <!--            android:layout_marginStart="@dimen/padding20"-->
                <!--            android:layout_marginLeft="@dimen/padding20"-->
                <!--            android:layout_marginTop="@dimen/padding10"-->
                <!--            android:gravity="center|start"-->
                <!--            android:hint="Are you a farmer ?"-->
                <!--            android:maxLines="1"-->
                <!--            android:textColor="@color/text_black"-->
                <!--            android:textSize="@dimen/text16"-->
                <!--            android:textStyle="bold" />-->


                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!--            <TextView-->
                    <!--                android:layout_width="match_parent"-->
                    <!--                android:layout_height="wrap_content"-->
                    <!--                android:layout_marginTop="@dimen/padding10"-->
                    <!--                android:gravity="start|center"-->
                    <!--                android:paddingEnd="@dimen/padding20"-->
                    <!--                android:paddingStart="@dimen/padding20"-->
                    <!--                android:text="District"-->
                    <!--                android:textColor="@color/heading"-->
                    <!--                android:textSize="@dimen/text16"-->
                    <!--                android:textStyle="bold" />-->

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/height5"
                        android:elevation="8dp"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/textViewDist"
                            android:layout_width="match_parent"
                            android:layout_height="60dp"
                            android:layout_marginHorizontal="20dp"
                            android:background="@drawable/login_edit_bg"
                            android:elevation="@dimen/_5sdp"
                            android:gravity="start|center"
                            android:hint="@string/farmer_select_district"
                            android:paddingHorizontal="@dimen/padding20"
                            android:textColor="@color/heading"
                            android:textColorHint="@color/text_black"
                            android:textSize="@dimen/text14"
                            android:textStyle="normal" />

                        <ImageView
                            android:id="@+id/imageviewDist"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_alignParentRight="true"
                            android:layout_centerVertical="true"
                            android:layout_marginEnd="@dimen/padding30"
                            android:layout_marginRight="@dimen/padding30"
                            android:contentDescription="@string/app_name"
                            android:elevation="@dimen/_5sdp"
                            app:srcCompat="@drawable/ic_expand_more_black_24dp"
                            app:tint="@color/gray"
                            tools:ignore="VectorDrawableCompat" />

                    </RelativeLayout>

                    <!--            <TextView-->
                    <!--                android:layout_width="match_parent"-->
                    <!--                android:layout_height="wrap_content"-->
                    <!--                android:layout_marginTop="@dimen/padding10"-->
                    <!--                android:gravity="start|center"-->
                    <!--                android:paddingEnd="@dimen/padding20"-->
                    <!--                android:paddingStart="@dimen/padding20"-->
                    <!--                android:text="Taluka"-->
                    <!--                android:textColor="@color/heading"-->
                    <!--                android:textSize="@dimen/text16"-->
                    <!--                android:textStyle="bold" />-->

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/height5"
                        android:elevation="8dp"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/textViewTaluka"
                            android:layout_width="match_parent"
                            android:layout_height="60dp"
                            android:layout_marginHorizontal="20dp"
                            android:background="@drawable/login_edit_bg"
                            android:elevation="@dimen/_5sdp"
                            android:gravity="start|center_vertical"
                            android:hint="@string/farmer_select_taluka"
                            android:paddingHorizontal="@dimen/padding20"
                            android:textColor="@color/heading"
                            android:textColorHint="@color/text_black"
                            android:textSize="@dimen/text14"
                            android:textStyle="normal" />

                        <ImageView
                            android:id="@+id/imageviewTaluka"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_alignParentRight="true"
                            android:layout_centerVertical="true"
                            android:layout_marginEnd="@dimen/padding30"
                            android:layout_marginRight="@dimen/padding30"
                            android:contentDescription="@string/app_name"
                            android:elevation="@dimen/_5sdp"
                            app:srcCompat="@drawable/ic_expand_more_black_24dp"
                            app:tint="@color/gray"
                            tools:ignore="VectorDrawableCompat" />

                    </RelativeLayout>

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:elevation="8dp"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/textViewVillage"
                            android:layout_width="match_parent"
                            android:layout_height="60dp"
                            android:layout_marginHorizontal="20dp"
                            android:background="@drawable/login_edit_bg"
                            android:elevation="@dimen/_5sdp"
                            android:gravity="start|center"
                            android:hint="@string/farmer_select_village"
                            android:paddingHorizontal="@dimen/padding20"
                            android:textColor="@color/heading"
                            android:textColorHint="@color/text_black"
                            android:textSize="@dimen/text14"
                            android:textStyle="normal" />

                        <ImageView
                            android:id="@+id/imageviewVillage"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_alignParentRight="true"
                            android:layout_centerVertical="true"
                            android:layout_marginEnd="@dimen/padding30"
                            android:layout_marginRight="@dimen/padding30"
                            android:contentDescription="@string/app_name"
                            android:elevation="@dimen/_5sdp"
                            app:srcCompat="@drawable/ic_expand_more_black_24dp"
                            app:tint="@color/gray"
                            tools:ignore="VectorDrawableCompat" />

                    </RelativeLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/submitButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginHorizontal="@dimen/_16sdp"
                        android:backgroundTint="@color/actionbar_color_figma"
                        android:padding="@dimen/padding12"
                        android:text="@string/reg_submit"
                        android:textAllCaps="false"
                        android:textColor="@color/white"
                        android:textSize="@dimen/text16"
                        app:cornerRadius="@dimen/_15sdp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/deleteAccountButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center|start"
                    android:hint="Delete Account"
                    android:paddingHorizontal="30dp"
                    android:paddingVertical="10dp"
                    android:textColorHint="@color/red"
                    android:visibility="gone" />

            </LinearLayout>
        </ScrollView>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>


<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/relLayoutGridItemSingle"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@color/colorListBackground"
    android:layout_gravity="center_horizontal">

    <RelativeLayout
        android:id="@+id/linearLayoutTopBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/colorListBackground"
        android:gravity="center_vertical"
        android:orientation="horizontal">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <LinearLayout
                android:id="@+id/linearLayoutName"
                android:layout_width="35dp"
                android:layout_height="105dp"
                android:background="@color/colorListBackground"
                android:gravity="center_horizontal">
                <TextView
                    android:id="@+id/textViewCryptoName"
                    android:layout_width="wrap_content"
                    android:layout_height="45dp"
                    android:ellipsize="marquee"
                    android:gravity="center"
                    android:textColor="@color/cardview_dark_background"
                    android:textSize="20dp" />
            </LinearLayout>
            <androidx.cardview.widget.CardView
                xmlns:card_view="http://schemas.android.com/apk/res-auto"
                android:layout_width="match_parent"
                card_view:cardCornerRadius="2dp"
                card_view:cardElevation="3dp"
                android:layout_height="wrap_content"
                android:layout_margin="2dp"
                card_view:cardUseCompatPadding="true"
                android:background="@color/colorListBackground">

                <LinearLayout
                    android:id="@+id/linearLayoutcard2"
                    android:layout_width="match_parent"
                    android:layout_height="105dp"
                    android:background="@drawable/cardview_list_white_background"
                    android:gravity="center_horizontal"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="15dp"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_margin="1dp"
                            android:layout_marginRight="5dp"
                            android:orientation="horizontal"
                            android:weightSum="2"
                            android:paddingRight="5dp">

                            <TextView
                                android:id="@+id/tv_crop_name"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginRight="5dp"
                                android:paddingTop="3dp"
                                android:text="Crop Name"
                                android:layout_weight="1.6"
                                android:layout_marginLeft="55dp"
                                android:textColor="@color/status_green"
                                android:textSize="12dp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tv_crop_date"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginRight="5dp"
                                android:text="Date:13/10/2021"
                                android:layout_weight="0.4"
                                android:gravity="center"
                                android:textColor="@color/black"
                                android:textSize="10dp"
                                android:textStyle="bold" />
                        </LinearLayout>


                        <View
                            android:layout_width="match_parent"
                            android:layout_height="0.5dp"
                            android:layout_marginLeft="5dp"
                            android:background="@color/status_green"
                            android:layout_marginRight="5dp"
                            android:layout_marginTop="2dp"
                            >

                        </View>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_margin="2dp"
                            android:layout_marginTop="2dp"
                            android:paddingLeft="@dimen/height50"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/tvMinPrice"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:backgroundTint="@color/colorTransparent"
                                android:drawableTint="@color/colorButtonBackground"
                                android:foregroundTint="@color/colorButtonBackground"
                                android:gravity="center_vertical"
                                android:hint="@string/min_Price"
                                android:textStyle="bold"
                                android:imeOptions="actionNext"
                                android:inputType="textCapSentences"
                                android:paddingLeft="5dp"
                                android:textColor="@color/colorPrimary"
                                android:textColorHint="@color/black"
                                android:textSize="12dp" />

                            <TextView
                                android:id="@+id/tvMinValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:backgroundTint="@color/colorTransparent"
                                android:drawableTint="@color/colorButtonBackground"
                                android:foregroundTint="@color/colorButtonBackground"
                                android:gravity="center_vertical"
                                android:imeOptions="actionNext"
                                android:inputType="textCapSentences"
                                android:text="10000"
                                android:textColor="@color/status_green"
                                android:textColorHint="@color/status_green"
                                android:textSize="12dp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_margin="2dp"
                            android:layout_marginTop="5dp"
                            android:paddingLeft="@dimen/height50"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/tvMaxPrice"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:backgroundTint="@color/colorTransparent"
                                android:drawableTint="@color/colorButtonBackground"
                                android:foregroundTint="@color/colorButtonBackground"
                                android:gravity="center_vertical"
                                android:hint="@string/max_Price"
                                android:imeOptions="actionNext"
                                android:textStyle="bold"
                                android:inputType="textCapSentences"
                                android:paddingLeft="5dp"
                                android:textColor="@color/colorPrimary"
                                android:textColorHint="@color/black"
                                android:textSize="12dp" />

                            <TextView
                                android:id="@+id/tvMaxValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:backgroundTint="@color/colorTransparent"
                                android:drawableTint="@color/colorButtonBackground"
                                android:foregroundTint="@color/colorButtonBackground"
                                android:gravity="center_vertical"
                                android:imeOptions="actionNext"
                                android:inputType="textCapSentences"
                                android:text="48000"
                                android:textColor="@color/status_green"
                                android:textColorHint="@color/status_green"
                                android:textSize="12dp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_margin="2dp"
                            android:layout_marginTop="2dp"
                            android:paddingLeft="@dimen/height50"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/tvAvgPrice"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:backgroundTint="@color/colorTransparent"
                                android:drawableTint="@color/colorButtonBackground"
                                android:foregroundTint="@color/colorButtonBackground"
                                android:gravity="center_vertical"
                                android:hint="@string/avg_Price"
                                android:textStyle="bold"
                                android:imeOptions="actionNext"
                                android:inputType="textCapSentences"
                                android:paddingLeft="5dp"
                                android:textColor="@color/colorPrimary"
                                android:textColorHint="@color/black"
                                android:textSize="12dp" />

                            <TextView
                                android:id="@+id/tvAvgValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:backgroundTint="@color/colorTransparent"
                                android:drawableTint="@color/colorButtonBackground"
                                android:foregroundTint="@color/colorButtonBackground"
                                android:gravity="center_vertical"
                                android:imeOptions="actionNext"
                                android:inputType="textCapSentences"
                                android:text="20000"
                                android:textColor="@color/status_green"
                                android:textColorHint="@color/status_green"
                                android:textSize="12dp"
                                android:textStyle="bold" />
                        </LinearLayout>


                        <View
                            android:layout_width="match_parent"
                            android:layout_height="0.5dp"
                            android:background="@color/status_green"
                            android:layout_marginTop="5dp"
                            android:layout_marginRight="5dp"
                            >
                        </View>

                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <ImageView
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:layout_marginLeft="5dp"
            android:elevation="5dp"
            android:background="@drawable/drawable_white_round_bacground"
            android:layout_centerVertical="true"
            android:src="@drawable/marketprece4"
            />
    </RelativeLayout>
</RelativeLayout>

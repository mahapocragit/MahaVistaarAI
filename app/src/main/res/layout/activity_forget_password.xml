<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".ui.screens.authentication.ForgetPassword">
    <include
        android:id="@+id/relativeLayoutTopBar"
        layout="@layout/layout_toolbar" />
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/padding30"
                android:layout_marginRight="@dimen/padding30"
                android:orientation="vertical">
                <EditText
                    android:id="@+id/mobileEditText"
                    android:layout_width="match_parent"
                    android:layout_height="70dp"
                    android:digits="0987654321"
                    android:gravity="center|start"
                    android:hint="Enter Your Mobile Number"
                    android:inputType="number"
                    android:maxLength="10"
                    android:maxLines="1"
                    android:paddingEnd="@dimen/padding20"
                    android:paddingStart="@dimen/padding20"
                    android:longClickable="false"
                    android:textIsSelectable="false" />

                <Button
                    android:id="@+id/sendOTPButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginBottom="@dimen/padding20"
                    android:layout_marginLeft="@dimen/padding30"
                    android:layout_marginRight="@dimen/padding30"
                    android:layout_marginTop="@dimen/padding10"
                    android:background="@color/purple_200"
                    android:padding="@dimen/padding10"
                    android:text="Get OTP"
                    android:textAllCaps="true"
                    android:textColor="@color/white"
                    android:textSize="@dimen/text16" />

            </LinearLayout>

</LinearLayout>
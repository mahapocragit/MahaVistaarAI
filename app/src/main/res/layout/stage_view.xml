<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="horizontal">


    <LinearLayout
        android:id="@+id/stages"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/height5"
        android:layout_marginTop="@dimen/height5"
        android:orientation="vertical">

        <RelativeLayout
            android:id="@+id/stage"
            android:layout_width="@dimen/height30"
            android:layout_height="@dimen/height30"
            android:layout_gravity="center"
            android:background="@drawable/pending_round_backgroud_stages">
            <ImageView
                android:id="@+id/right_tick"
                android:layout_width="@dimen/height25"
                android:layout_height="@dimen/height25"
                android:visibility="gone"
                android:layout_centerInParent="true"
                android:src="@drawable/right_tick">
            </ImageView>
        </RelativeLayout>

        <TextView
            android:id="@+id/titleTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:paddingTop="2dp"
            android:paddingLeft="10dp"

            android:paddingRight="10dp"
            android:text="TextView"
            android:textColor="@color/status_green"
            android:textSize="12sp"
            android:textStyle="bold"
            tools:ignore="MissingConstraints" />


    </LinearLayout>

    <View
        android:id="@+id/stepLine"
        android:layout_width="@dimen/height30"
        android:layout_height="2dp"
        android:layout_gravity="center"
        android:layout_marginRight="@dimen/height10"
        android:layout_marginBottom="@dimen/height10"
        android:background="@color/black"
        android:visibility="visible">

    </View>


</LinearLayout>
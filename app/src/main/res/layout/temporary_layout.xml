<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_marginTop="@dimen/_48sdp"
    tools:showIn="@layout/app_bar_maintwo">

    <LinearLayout
        android:id="@+id/temperatureLayout"
        android:layout_width="match_parent"
        android:layout_height="@dimen/_90sdp"
        android:layout_margin="@dimen/_5sdp"
        android:background="@drawable/gradient_bg"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginStart="24dp"
            android:layout_weight="4"
            android:gravity="center_vertical"
            android:orientation="vertical">

            <TextView
                android:id="@+id/timestamp_textView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="13 February 2025 | 14:00"
                android:textColor="@color/white"
                android:textSize="@dimen/_11sdp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/temperatureTextView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="22°C"
                    android:textColor="@color/white"
                    android:textSize="@dimen/_18sdp"
                    android:textStyle="bold"
                    android:visibility="visible" />

                <ProgressBar
                    android:id="@+id/progressBar"
                    style="?android:attr/progressBarStyle"
                    android:layout_width="@dimen/_20sdp"
                    android:layout_height="@dimen/_20sdp"
                    android:gravity="start"
                    android:indeterminateTint="@android:color/white"
                    android:indeterminateTintMode="src_in"
                    android:visibility="visible" />
            </LinearLayout>

            <TextView
                android:id="@+id/weatherTalukaTV"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Mumbai"
                android:textColor="@color/white"
                android:textSize="@dimen/_12sdp" />

        </LinearLayout>

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:layout_weight="6"
            app:srcCompat="@drawable/weather_icon_figma" />
    </LinearLayout>


    <LinearLayout
        android:id="@+id/AddCrop"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/_10sdp"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@+id/temperatureLayout">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            tools:layout_editor_absoluteX="1dp"
            tools:layout_editor_absoluteY="235dp">

            <LinearLayout
                android:id="@+id/etlWarningLayout"
                android:layout_width="match_parent"
                android:layout_height="@dimen/_20sdp"
                android:visibility="gone"
                android:background="@color/yeellowies"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/imageView14"
                    android:layout_width="@dimen/_20sdp"
                    android:layout_height="match_parent"
                    android:layout_marginStart="@dimen/_10sdp"
                    app:srcCompat="@drawable/ic_warning" />

                <TextView
                    android:id="@+id/textView2"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:layout_marginStart="@dimen/_5sdp"
                    android:textColor="@color/red"
                    android:text="@string/etl_crossed_click_here_for_advisory" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/greetingsTextView"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_marginStart="@dimen/_10sdp"
                    android:gravity="center_vertical"
                    android:text="Good Morning,"
                    android:textSize="@dimen/_12sdp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/userFullNameTextView"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginStart="@dimen/_5sdp"
                    android:layout_weight="4"
                    android:gravity="center_vertical"
                    android:text="Lorem Ipsum"
                    android:textSize="@dimen/_12sdp" />
            </LinearLayout>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="@dimen/_60sdp"
                android:layout_margin="@dimen/_10sdp"
                android:backgroundTint="@color/card_background_color_figma_dash"
                app:cardCornerRadius="@dimen/_15sdp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/_85sdp"
                        android:layout_weight="1"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/yourCropTv"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_vertical"
                            android:layout_weight="1"
                            android:paddingStart="@dimen/_10sdp"
                            android:text="@string/no_crops_added"
                            android:textSize="@dimen/_10sdp"
                            android:visibility="visible" />

                        <LinearLayout
                            android:id="@+id/savedCropNameCardView"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/_10sdp"
                            android:layout_marginEnd="@dimen/_10sdp"
                            android:paddingVertical="@dimen/_6sdp"
                            android:orientation="horizontal"
                            android:visibility="gone"
                            android:gravity="center_vertical"> <!-- Optional background -->

                            <!-- Image with circular background -->
                            <FrameLayout
                                android:layout_width="@dimen/_38sdp"
                                android:layout_height="@dimen/_38sdp"
                                android:background="@drawable/shape_round_gray">

                                <de.hdodenhof.circleimageview.CircleImageView
                                    android:id="@+id/savedCropNameImageView"
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    app:civ_border_width="@dimen/_1sdp"
                                    app:civ_border_color="#CBD5E1"
                                    android:scaleType="centerCrop"
                                    android:src="@drawable/trigo" />
                            </FrameLayout>

                            <!-- Crop name with wrapping text -->
                            <TextView
                                android:id="@+id/savedCropNameTextView"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="@dimen/_8sdp"
                                android:layout_marginEnd="@dimen/_8sdp"
                                android:layout_weight="1"
                                android:maxLines="2"
                                android:ellipsize="end"
                                android:text="Crop Name"
                                android:textColor="@color/font_color_figma"
                                android:textStyle="bold"
                                android:textSize="@dimen/_10sdp" />

                            <!-- Change button -->
                            <TextView
                                android:id="@+id/changeCropText"
                                android:layout_width="@dimen/_60sdp"
                                android:layout_height="wrap_content"
                                android:layout_marginEnd="@dimen/_4sdp"
                                android:textColor="@color/white"
                                android:background="@drawable/background_for_chat_request_green"
                                android:gravity="center"
                                android:textSize="@dimen/_10sdp"
                                android:paddingVertical="@dimen/_6sdp"
                                android:text="@string/change" />

                            <!-- Delete button -->
                            <TextView
                                android:id="@+id/deleteCropImageView"
                                android:layout_width="@dimen/_60sdp"
                                android:layout_height="wrap_content"
                                android:layout_marginEnd="@dimen/_4sdp"
                                android:textColor="@color/red"
                                android:background="@drawable/background_for_delete_request"
                                android:gravity="center"
                                android:textSize="@dimen/_10sdp"
                                android:paddingVertical="@dimen/_6sdp"
                                android:text="@string/delete" />

                        </LinearLayout>


                        <androidx.cardview.widget.CardView
                            android:id="@+id/addCropCardView"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/_40sdp"
                            android:layout_gravity="center_vertical"
                            android:layout_marginVertical="@dimen/_2sdp"
                            android:layout_marginEnd="@dimen/_5sdp"
                            android:layout_weight="1"
                            android:visibility="visible"
                            app:cardCornerRadius="@dimen/_25sdp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:layout_marginStart="@dimen/_10sdp"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <androidx.constraintlayout.widget.ConstraintLayout
                                    android:layout_width="@dimen/_30sdp"
                                    android:layout_height="@dimen/_30sdp"
                                    android:background="@drawable/shape_round_gray">

                                    <ImageView
                                        android:layout_width="@dimen/_30sdp"
                                        android:layout_height="@dimen/_30sdp"
                                        android:padding="@dimen/_8sdp"
                                        android:src="@drawable/trigo"
                                        app:layout_constraintBottom_toBottomOf="parent"
                                        app:layout_constraintEnd_toEndOf="parent"
                                        app:layout_constraintStart_toStartOf="parent"
                                        app:layout_constraintTop_toTopOf="parent" />
                                </androidx.constraintlayout.widget.ConstraintLayout>


                                <TextView
                                    android:id="@+id/addChangeCropTV"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="@dimen/_6sdp"
                                    android:layout_weight="1"
                                    android:text="@string/add_Crop"
                                    android:textColor="@color/font_color_figma"
                                    android:textStyle="bold" />

                                <ImageView
                                    android:id="@+id/addChangeCropIV"
                                    android:layout_width="@dimen/_20sdp"
                                    android:layout_height="@dimen/_20sdp"
                                    android:layout_marginEnd="@dimen/_10sdp"
                                    android:padding="@dimen/_2sdp"
                                    app:srcCompat="@drawable/baseline_add_24"
                                    app:tint="@color/arrow_color_figma" />

                            </LinearLayout>
                        </androidx.cardview.widget.CardView>

                    </LinearLayout>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/selectedCropRecyclerView"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:scrollbarAlwaysDrawHorizontalTrack="true"
                        android:scrollbarStyle="insideOverlay"
                        android:scrollbars="horizontal"
                        android:visibility="gone">

                    </androidx.recyclerview.widget.RecyclerView>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

    </LinearLayout>

    <GridView
        android:id="@+id/gridViewDashboard"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:horizontalSpacing="10dp"
        android:numColumns="3"
        android:paddingHorizontal="10dp"
        android:verticalSpacing="10dp"
        android:layout_marginBottom="@dimen/_4sdp"
        app:layout_constraintBottom_toTopOf="@+id/imageView20"
        app:layout_constraintTop_toBottomOf="@+id/AddCrop" >

    </GridView>

    <LinearLayout
        android:id="@+id/linearLayout13"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <include
            android:id="@+id/customNavBottom"
            layout="@layout/custom_bottom_nav" />
    </LinearLayout>

    <ImageView
        android:id="@+id/imageView20"
        android:layout_width="@dimen/_58sdp"
        android:layout_height="@dimen/_58sdp"
        android:layout_marginBottom="@dimen/_20sdp"
        app:layout_constraintBottom_toBottomOf="@+id/linearLayout13"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@+id/linearLayout13"
        app:srcCompat="@drawable/ic_chatbot" />

</androidx.constraintlayout.widget.ConstraintLayout>
<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".sma.KTDetailsHistory">
        <!-- App Toolbar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/primary_green"
        app:title="@string/view_kt_details"
        app:titleTextAppearance="@style/ToolbarTitleStyle"
        app:titleTextColor="@android:color/white"
        app:navigationIcon="@drawable/ic_arrow_left_back_24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Scrollable Content -->
        <androidx.core.widget.NestedScrollView
            android:id="@+id/scrollView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            app:layout_behavior="@string/appbar_scrolling_view_behavior"
            android:padding="12dp"
            android:layout_marginTop="?attr/actionBarSize">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal">

                <!-- CardView container -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="8dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="8dp"
                    android:backgroundTint="@android:color/white">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="#ddf4d7"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <!-- Header: Category Type -->
                        <TextView
                            android:id="@+id/tvCategoryType"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Visit"
                            android:textColor="#1E88E5"
                            android:textStyle="bold"
                            android:textSize="18sp"
                            android:layout_gravity="center_horizontal"
                            android:layout_marginBottom="5dp" />
                        <TextView
                            android:id="@+id/tvDate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="2025-10-20"
                            android:textColor="@color/black"
                            android:paddingLeft="5dp"
                            android:paddingRight="5dp"
                            android:background="@drawable/bg_absent_card"
                            android:textSize="13sp"
                            android:layout_gravity="end"
                            tools:ignore="HardcodedText" />

                        <!-- Image -->
                        <ImageView
                            android:id="@+id/imgPhoto"
                            android:layout_width="match_parent"
                            android:layout_height="200dp"
                            android:scaleType="centerCrop"
                            android:adjustViewBounds="true"
                            android:layout_marginBottom="10dp"
                            android:background="#EEEEEE"
                            android:contentDescription="Image" />

                        <!-- Category Details -->
                        <TextView
                            android:id="@+id/tvCategoryName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Category :  हवामान अनुकूल तंत्रज्ञान"
                            android:textColor="@color/colorPrimaryDark"
                            android:textSize="16sp"
                            android:visibility="gone"
                            android:textStyle="bold"
                            android:layout_marginBottom="6dp" />
                        <TextView
                            android:id="@+id/tvCategoryNameOther"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Category :  हवामान अनुकूल तंत्रज्ञान"
                            android:textColor="@color/colorPrimaryDark"
                            android:textSize="16sp"
                            android:visibility="gone"
                            android:textStyle="bold"
                            android:layout_marginBottom="6dp" />

                        <!-- Farmer Details -->
                        <TextView
                            android:id="@+id/tvRegisterName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Farmer Name: मयुरी कासार"
                            android:textColor="#000000"
                            android:textStyle="normal"
                            android:visibility="gone"
                            android:textSize="15sp"
                            android:layout_marginBottom="6dp" />

                        <TextView
                            android:id="@+id/tvMobileNumber"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Mobile: 8104137847"
                            android:textColor="#000000"
                            android:visibility="gone"
                            android:layout_marginBottom="6dp"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tvSubcategoryName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Subcategory: कामगंध सापळे"
                            android:textColor="#424242"
                            android:visibility="gone"
                            android:textSize="15sp"
                            android:layout_marginBottom="6dp" />

                        <TextView
                            android:id="@+id/tvFarmerGroupName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Farmer Group: कृषी गट अ"
                            android:textColor="#424242"
                            android:visibility="gone"
                            android:textSize="15sp"
                            android:layout_marginBottom="4dp" />
                        <TextView
                            android:id="@+id/tvFarmerGroupOtherText"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Farmer Group Other"
                            android:textColor="#424242"
                            android:visibility="gone"
                            android:textSize="15sp"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:id="@+id/tvDiscussionName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Discussion: कीटक व्यवस्थापन"
                            android:textColor="#424242"
                            android:visibility="gone"
                            android:textSize="15sp"
                            android:layout_marginBottom="8dp" />

                        <!-- Row: Technology + Farmer Type -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:weightSum="2"
                            android:layout_marginBottom="8dp">

                            <TextView
                                android:id="@+id/tvTechnologyType"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Technology: 1"
                                android:visibility="gone"
                                android:textColor="#616161"
                                android:textSize="14sp" />

                            <TextView
                                android:id="@+id/tvFarmerType"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:visibility="gone"
                                android:text="Farmer Type: 1"
                                android:textColor="#616161"
                                android:textSize="14sp" />
                        </LinearLayout>

                        <!-- Description -->
                        <TextView
                            android:id="@+id/tvDescription"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Description: Test details here..."
                            android:textColor="#1E88E5"
                            android:textSize="14sp"
                            android:visibility="gone"
                            android:lineSpacingExtra="3dp"
                            android:layout_marginBottom="12dp" />

                        <!-- Divider -->
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="#E0E0E0"
                            android:layout_marginVertical="8dp" />


                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
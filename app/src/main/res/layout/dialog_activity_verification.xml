<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    android:layout_margin="@dimen/padding10"
    android:orientation="vertical">

    <ImageView
        android:id="@+id/imageView_close"
        android:layout_width="@dimen/height25"
        android:layout_height="@dimen/height25"
        android:layout_gravity="top|right"
        android:clickable="true"
        android:src="@drawable/close_dialog_bt" />

    <TextView
        android:id="@+id/dialogTitle"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:paddingEnd="@dimen/padding20"
        android:paddingRight="@dimen/padding20"
        android:text="Enter OTP"
        android:textColor="@color/green"
        android:textSize="@dimen/text16"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/countdownTextview"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="TextView" />

    <LinearLayout
        android:id="@+id/layoutmain"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        android:orientation="vertical">
    </LinearLayout>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/height45"
        android:layout_marginTop="@dimen/padding5"
        android:orientation="horizontal">

        <EditText
            android:id="@+id/OptEditText"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/drop_down"
            android:gravity="start|center"
            android:inputType="number"
            android:maxLength="6"
            android:paddingStart="@dimen/padding20"
            android:paddingEnd="@dimen/padding20"
            android:textColor="@color/heading"
            android:textSize="@dimen/text14"
            android:textStyle="normal" />

    </RelativeLayout>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <Button
            android:id="@+id/submitButton"
            android:layout_width="0dp"
            android:layout_height="@dimen/height55"
            android:layout_margin="@dimen/padding10"
            android:layout_weight="1"
            android:backgroundTint="@color/status_green"
            android:padding="@dimen/padding10"
            android:text="@string/reg_verify"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="@dimen/text16" />

        <Button
            android:id="@+id/resentOTP"
            android:layout_width="0dp"
            android:layout_height="@dimen/height55"
            android:layout_margin="@dimen/padding10"
            android:layout_weight="1"
            android:backgroundTint="@color/status_green"
            android:padding="@dimen/padding10"
            android:text="@string/Resend_OTP"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="@dimen/text16" />
    </LinearLayout>
</LinearLayout>
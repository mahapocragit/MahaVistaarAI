<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/text_bg_with_border"
    android:layout_marginBottom="@dimen/height20"
   android:layout_marginRight="@dimen/padding2"
    android:layout_marginLeft="@dimen/padding2"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <LinearLayout
        android:id="@+id/mainLinearLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/padding1"
        android:orientation="vertical">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/optiontv"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/btn_bg"
            android:gravity="center"
            android:paddingTop="@dimen/height10"
            android:paddingBottom="@dimen/height5"
            android:text="@string/Option"
            android:paddingStart="@dimen/padding10"
            android:paddingEnd="@dimen/padding10"
            android:textColor="@color/white"
            android:textSize="@dimen/text14"
            android:textStyle="normal" />

        <ImageView
            android:id="@+id/optionImg"
            android:layout_width="30dp"
            android:layout_height="20dp"
            android:layout_alignParentEnd="true"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"
            android:visibility="visible"
            android:layout_marginEnd="@dimen/padding20"
            android:layout_marginRight="@dimen/padding30"
            android:contentDescription="@string/app_name"
            android:background="@color/white"
            app:srcCompat="@drawable/login_edit_bg"
            tools:ignore="VectorDrawableCompat" />

        <ImageView
            android:id="@+id/deleteOptionImageView"
            android:layout_width="30dp"
            android:layout_height="20dp"
            android:layout_alignParentEnd="true"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"
            android:visibility="visible"
            android:layout_marginEnd="@dimen/padding20"
            android:layout_marginRight="@dimen/padding30"
            android:contentDescription="@string/app_name"
            android:background="@color/white"
            app:srcCompat="@drawable/delete_icon"
            tools:ignore="VectorDrawableCompat" />
    </RelativeLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/fertlizerDate_Rcl"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbarAlwaysDrawHorizontalTrack="true"
        android:scrollbarStyle="insideOverlay"
        android:scrollbars="horizontal">
    </androidx.recyclerview.widget.RecyclerView>

    </LinearLayout>

</LinearLayout>
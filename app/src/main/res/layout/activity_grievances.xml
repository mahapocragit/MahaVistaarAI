<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bottom_bg_color"
    tools:context=".activity.Grievances">

    <include
        android:id="@+id/relativeLayoutTopBar"
        layout="@layout/layout_toolbar" />

    <ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_margin="20dp"
                android:background="@color/transparent_green"
                android:elevation="@dimen/height5"
                android:gravity="center"
                android:orientation="vertical">

                <EditText
                    android:id="@+id/nameEditText"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_marginLeft="20dp"
                    android:layout_marginTop="10dp"
                    android:layout_marginRight="20dp"
                    android:background="@drawable/login_edit_bg"
                    android:digits="@string/name_validation"
                    android:elevation="8dp"
                    android:gravity="center|start"
                    android:hint="Enter Your Name"
                    android:inputType="text"
                    android:maxLength="30"
                    android:maxLines="1"
                    android:paddingStart="@dimen/padding20"
                    android:paddingEnd="@dimen/padding20"
                    android:textColor="@color/black"
                    android:textColorHint="@color/text_black"
                    android:textSize="@dimen/text12" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="2">
                    <EditText
                        android:id="@+id/mobNoEditText"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:layout_marginLeft="20dp"
                        android:layout_marginRight="20dp"
                        android:layout_weight="0.5"
                        android:background="@drawable/login_edit_bg"
                        android:digits="@string/numeric"
                        android:elevation="8dp"
                        android:gravity="center|start"
                        android:hint="Enter Your Mobile Number"
                        android:inputType="number"
                        android:maxLength="10"
                        android:maxLines="1"
                        android:paddingStart="@dimen/padding20"
                        android:paddingEnd="@dimen/padding20"
                        android:textColor="@color/black"
                        android:textColorHint="@color/text_black"
                        android:textSize="@dimen/text12" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="2">
                    <EditText
                        android:id="@+id/issue_address"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:layout_marginLeft="20dp"
                        android:layout_marginRight="20dp"
                        android:layout_weight="0.5"
                        android:background="@drawable/login_edit_bg"
                        android:elevation="8dp"
                        android:textColor="@color/black"
                        android:gravity="center|start"
                        android:hint="@string/area_of_issues"
                        android:inputType="none"
                        android:maxLength="10"
                        android:maxLines="1"
                        android:paddingStart="@dimen/padding20"
                        android:paddingEnd="@dimen/padding20"
                        android:textColorHint="@color/text_black"
                        android:textSize="@dimen/text12" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/height5"
                        android:elevation="8dp"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/textViewCategories"
                            android:layout_width="match_parent"
                            android:layout_height="40dp"
                            android:layout_marginLeft="20dp"
                            android:layout_marginRight="20dp"
                            android:background="@drawable/drop_down"
                            android:gravity="start|center"
                            android:hint="@string/grivience_categories"
                            android:paddingStart="@dimen/padding20"
                            android:paddingEnd="@dimen/padding20"

                            android:textColor="@color/heading"
                            android:textColorHint="@color/text_black"
                            android:textSize="@dimen/text14"
                            android:textStyle="normal" />

                        <ImageView
                            android:id="@+id/imageviewDist"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_alignParentRight="true"
                            android:layout_centerVertical="true"
                            android:layout_marginEnd="@dimen/padding30"
                            android:layout_marginRight="@dimen/padding30"
                            android:contentDescription="@string/app_name"
                            app:srcCompat="@drawable/ic_expand_more_black_24dp"
                            app:tint="@color/gray"
                            tools:ignore="VectorDrawableCompat" />
                    </RelativeLayout>

                    <EditText
                        android:id="@+id/grievance_descpt"
                        android:layout_width="match_parent"
                        android:layout_height="200dp"
                        android:layout_marginLeft="20dp"
                        android:layout_marginRight="20dp"
                        android:background="@drawable/login_edit_bg"
                        android:elevation="8dp"
                        android:gravity="top|left"
                        android:hint="@string/grievance"
                        android:inputType="text"
                        android:textColor="@color/black"
                        android:padding="15dp"
                        android:paddingStart="@dimen/padding10"
                        android:paddingEnd="@dimen/padding10"
                        android:textColorHint="@color/text_black"
                        android:textSize="@dimen/text12" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/height5"
                        android:layout_gravity="center"
                        android:orientation="horizontal">


<!--                        <RelativeLayout-->
<!--                            android:layout_width="match_parent"-->
<!--                            android:layout_height="wrap_content"-->
<!--                            android:layout_marginBottom="@dimen/height15"-->
<!--                            android:layout_weight="0.5"-->
<!--                            android:elevation="8dp"-->
<!--                            android:orientation="horizontal">-->

<!--                            <TextView-->
<!--                                android:id="@+id/textViewDoc"-->
<!--                                android:layout_width="match_parent"-->
<!--                                android:layout_height="40dp"-->
<!--                                android:layout_marginLeft="20dp"-->
<!--                                android:layout_marginRight="20dp"-->
<!--                                android:background="@drawable/drop_down"-->
<!--                                android:gravity="start|center"-->
<!--                                android:hint="@string/doc_upload"-->
<!--                                android:paddingStart="@dimen/padding20"-->
<!--                                android:paddingEnd="@dimen/padding20"-->

<!--                                android:textColor="@color/heading"-->
<!--                                android:textColorHint="@color/text_black"-->
<!--                                android:textSize="@dimen/text14"-->
<!--                                android:textStyle="normal" />-->

<!--                            <ImageView-->
<!--                                android:id="@+id/imageviewDoc"-->
<!--                                android:layout_width="wrap_content"-->
<!--                                android:layout_height="wrap_content"-->
<!--                                android:layout_alignParentEnd="true"-->
<!--                                android:layout_alignParentRight="true"-->
<!--                                android:layout_centerVertical="true"-->
<!--                                android:layout_marginEnd="@dimen/padding30"-->
<!--                                android:layout_marginRight="@dimen/padding30"-->
<!--                                android:contentDescription="@string/app_name"-->
<!--                                app:srcCompat="@drawable/ic_expand_more_black_24dp"-->
<!--                                app:tint="@color/gray"-->
<!--                                tools:ignore="VectorDrawableCompat" />-->
<!--                        </RelativeLayout>-->

                        <TextView
                            android:id="@+id/textViewVerify"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="20dp"
                            android:layout_marginRight="@dimen/height20"
                            android:background="@color/status_green"
                            android:padding="@dimen/height5"
                            android:gravity="center"
                            android:text="@string/image_upload"
                            android:textColor="@color/white"
                            android:textSize="@dimen/text14"
                            android:textStyle="bold">

                        </TextView>
                    </LinearLayout>

                    <ImageView
                        android:id="@+id/grievancesImage"
                        android:layout_width="100dp"
                        android:layout_height="100dp"
                        android:layout_gravity="center"
                        android:layout_marginTop="@dimen/text8"
                        android:layout_marginBottom="@dimen/text8"
                        android:padding="@dimen/text8"
                        android:src="@drawable/camera" />

                    <Button
                        android:id="@+id/grievancePdfLLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@color/colorPrimary"
                        android:padding="5dp"
                        android:layout_marginTop="@dimen/text10"
                        android:scaleType="centerCrop"
                        android:text="@string/image_pdf"
                        android:backgroundTint="@color/status_green"
                        android:textSize="@dimen/text14"
                        android:textAllCaps="false"
                        android:textColor="@color/white" />

                </LinearLayout>

            </LinearLayout>

            <Button
                android:id="@+id/submitButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_margin="30dp"
                android:backgroundTint="@color/status_green"
                android:padding="@dimen/padding12"
                android:text="@string/reg_submit"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="@dimen/text16" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>


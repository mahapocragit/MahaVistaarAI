<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    >

<!--<ScrollView-->
<!--    android:layout_width="match_parent"-->
<!--    android:layout_height="match_parent">-->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/cropicons1"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:background="@drawable/current_round_background_status"
                    android:src="@drawable/pets_n_disease_img"/>

                <TextView
                    android:id="@+id/stages"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="@dimen/height10"
                    android:text="Fruiting Stage"
                    android:textColor="@color/colorAccent"
                    android:textSize="@dimen/text16">
                </TextView>
            </LinearLayout>

            <GridView
                android:id="@+id/gridViewJobs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:horizontalSpacing="1dp"
                android:nestedScrollingEnabled="true"
                android:numColumns="2"
                android:paddingRight="10dp"
                >
            </GridView>

            <TextView
                android:id="@+id/seeMoreTx2"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_gravity="center"
                android:background="@drawable/yellow_bg_gradient"
                android:elevation="2dp"
                android:gravity="center"
                android:padding="@dimen/height5"
                android:text="@string/see_more"
                android:textAllCaps="false"
                android:textColor="@color/black"
                android:textSize="11sp"
                android:textStyle="bold">
            </TextView>
        </LinearLayout>

<!--</ScrollView>-->




</LinearLayout>
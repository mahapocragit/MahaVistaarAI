<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".sma.ui.screens.KTActivity">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar2"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="?attr/colorPrimary"
            app:title="@string/activity"
            app:titleTextAppearance="@style/ToolbarTitleStyle"
            app:titleTextColor="@android:color/white"
            app:navigationIcon="@drawable/ic_arrow_left_back_24dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />
        <ScrollView
        xmlns:android="http://schemas.android.com/apk/res/android"
        android:layout_width="match_parent"
        android:background="@color/grey_300"
        android:layout_height="match_parent">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_margin="5dp"
            android:elevation="6dp"
            android:padding="2dp"
            android:orientation="vertical">
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:elevation="5dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:elevation="@dimen/height5"
                    android:gravity="center"
                    android:layout_marginTop="20dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/KT_Name"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:layout_marginLeft="20dp"
                        android:layout_marginRight="20dp"
                        android:digits="@string/name_validation"
                        android:gravity="center|start"
                        android:hint="कृषीताई नाव"
                        android:background="@drawable/dropdown_border"
                        android:inputType="text"
                        android:maxLength="30"
                        android:maxLines="1"
                        android:paddingStart="@dimen/padding20"
                        android:paddingEnd="@dimen/padding20"
                        android:textColorHint="@color/heading"
                        android:textSize="@dimen/text14" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="10dp">

                        <!-- ================= IMAGE OPTIONS ================= -->
                        <LinearLayout
                            android:id="@+id/layoutImageOptions"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center"
                            android:weightSum="3">

                            <!-- Option 1 -->
                            <LinearLayout
                                android:id="@+id/option1"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:orientation="vertical"
                                android:padding="2dp">

                                <ImageView
                                    android:id="@+id/img1"
                                    android:layout_width="80dp"
                                    android:layout_height="120dp"
                                    android:src="@drawable/ktbaithak"
                                    android:scaleType="centerCrop"
                                    android:background="@drawable/circle_bg"
                                    android:padding="2dp" />
                            </LinearLayout>

                            <!-- Option 2 -->
                            <LinearLayout
                                android:id="@+id/option2"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:orientation="vertical"
                                android:padding="2dp">

                                <ImageView
                                    android:id="@+id/img2"
                                    android:layout_width="80dp"
                                    android:layout_height="120dp"
                                    android:src="@drawable/ktprashikshan"
                                    android:scaleType="centerCrop"
                                    android:background="@drawable/circle_bg"
                                    android:padding="2dp" />
                            </LinearLayout>

                            <!-- Option 3 -->
                            <LinearLayout
                                android:id="@+id/option3"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:orientation="vertical"
                                android:padding="2dp">

                                <ImageView
                                    android:id="@+id/img3"
                                    android:layout_width="80dp"
                                    android:layout_height="120dp"
                                    android:src="@drawable/ktbhet"
                                    android:scaleType="centerCrop"
                                    android:background="@drawable/circle_bg"
                                    android:padding="2dp" />
                            </LinearLayout>

                        </LinearLayout>

                        <!-- ============= RADIO BUTTON OPTIONS ============= -->
                        <RadioGroup
                            android:id="@+id/radioGroupOptions"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center"
                            android:padding="5dp"
                            android:weightSum="3">

                            <RadioButton
                                android:id="@+id/rb1_Baithak"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="बैठक"
                                android:layout_gravity="center"
                                android:checked="true"
                                android:theme="@style/RadioButtonStyle" />

                            <RadioButton
                                android:id="@+id/rb2_Prashikshan"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginLeft="10dp"
                                android:layout_gravity="center"
                                android:text="प्रशिक्षण"
                                android:theme="@style/RadioButtonStyle" />

                            <RadioButton
                                android:id="@+id/rb3_Bhet"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginLeft="20dp"
                                android:layout_gravity="center"
                                android:text="भेट"
                                android:theme="@style/RadioButtonStyle" />

                        </RadioGroup>

                    </LinearLayout>



                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/height45"
                        android:layout_marginTop="@dimen/padding5"
                        android:layout_marginLeft="20dp"
                        android:visibility="gone"
                        android:layout_marginRight="20dp"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/reasonDropTextView"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/dropdown_border"
                            android:gravity="start|center"
                            android:hint="कामाचे स्वरूप निवडा"
                            android:paddingEnd="@dimen/padding20"
                            android:paddingStart="@dimen/padding20"
                            android:textColor="@color/heading"
                            android:textSize="@dimen/text14"
                            android:textStyle="normal" />

                        <ImageView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:layout_marginEnd="@dimen/padding20"
                            android:contentDescription="@string/app_name"
                            android:hint="@color/gray"
                            android:src="@drawable/ic_expand_more_black_24dp"
                            tools:ignore="VectorDrawableCompat" />

                    </RelativeLayout>
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/height45"
                        android:layout_marginTop="@dimen/padding5"
                        android:layout_marginLeft="20dp"
                        android:visibility="gone"
                        android:layout_marginRight="20dp"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/categoryDropTextView"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/dropdown_border"
                            android:gravity="start|center"
                            android:hint="कामाचा प्रकार निवडा"
                            android:paddingEnd="@dimen/padding20"
                            android:paddingStart="@dimen/padding20"
                            android:textColor="@color/heading"
                            android:textSize="@dimen/text14"
                            android:textStyle="normal" />

                        <ImageView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:layout_marginEnd="@dimen/padding20"
                            android:contentDescription="@string/app_name"
                            android:hint="@color/gray"
                            android:src="@drawable/ic_expand_more_black_24dp"
                            tools:ignore="VectorDrawableCompat" />

                    </RelativeLayout>
                    <LinearLayout
                        android:id="@+id/linLayoutCategoryOther"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:visibility="gone"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="45dp"
                            android:gravity="start|center"
                            android:text="इतर"
                            android:layout_marginTop="@dimen/padding5"
                            android:layout_marginLeft="20dp"
                            android:layout_marginRight="20dp"
                            android:paddingEnd="@dimen/padding20"
                            android:paddingStart="2dp"
                            android:textColor="@color/black"
                            android:textSize="@dimen/text14"
                            android:textStyle="normal" />
                        <EditText
                            android:id="@+id/categoryOtherEditText"
                            android:layout_width="match_parent"
                            android:layout_height="45dp"
                            android:background="@drawable/dropdown_border"
                            android:gravity="start|center"
                            android:hint="👉  येथे लिहा"
                            android:layout_marginTop="2dp"
                            android:layout_marginLeft="20dp"
                            android:layout_marginRight="20dp"
                            android:paddingEnd="@dimen/padding20"
                            android:paddingStart="@dimen/padding20"
                            android:textColor="@color/black"
                            android:textSize="@dimen/text14"
                            android:textStyle="normal" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/linLayoutCategory3"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:visibility="gone"
                        android:orientation="vertical">
                        <RadioGroup
                            android:id="@+id/radioGroupFarmer"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@color/white"
                            android:orientation="horizontal"
                            android:paddingStart="@dimen/padding30"
                            android:paddingTop="@dimen/padding10"
                            android:paddingEnd="@dimen/padding10"
                            android:paddingBottom="@dimen/padding10">
                            <RadioButton
                                android:id="@+id/farmerRBtnOne"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="वैयक्तिक शेतकरी            "
                                android:checked="true"
                                android:theme="@style/RadioButtonStyle" />
                            <RadioButton
                                android:id="@+id/farmerRBtnTwo"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="शेतकरी गट        "
                                android:theme="@style/RadioButtonStyle" />

                        </RadioGroup>
                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/height45"
                            android:layout_marginTop="@dimen/padding5"
                            android:layout_marginLeft="20dp"
                            android:layout_marginRight="20dp"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/farmerListDropTextView"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/dropdown_border"
                                android:gravity="start|center"
                                android:hint="शेतकरी निवडा"
                                android:paddingEnd="@dimen/padding20"
                                android:paddingStart="@dimen/padding20"
                                android:textColor="@color/heading"
                                android:textSize="@dimen/text14"
                                android:textStyle="normal" />

                            <ImageView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:layout_centerVertical="true"
                                android:layout_marginEnd="@dimen/padding20"
                                android:contentDescription="@string/app_name"
                                android:hint="@color/gray"
                                android:src="@drawable/ic_expand_more_black_24dp"
                                tools:ignore="VectorDrawableCompat" />

                        </RelativeLayout>
                        <RadioGroup
                            android:id="@+id/radioGroupTechnology"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@color/white"
                            android:orientation="horizontal"
                            android:paddingStart="@dimen/padding30"
                            android:paddingTop="@dimen/padding10"
                            android:paddingEnd="@dimen/padding10"
                            android:paddingBottom="@dimen/padding10">
                            <RadioButton
                                android:id="@+id/technologyRBtnOne"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="तंत्रज्ञान प्रात्यक्षिक           "
                                android:checked="true"
                                android:theme="@style/RadioButtonStyle" />
                            <RadioButton
                                android:id="@+id/technologyRBtnTwo"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="तंत्रज्ञान अवलंब        "
                                android:theme="@style/RadioButtonStyle" />

                        </RadioGroup>
                        <RelativeLayout
                            android:id="@+id/relativeLayoutSubCategory"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/height45"
                            android:layout_marginTop="@dimen/padding5"
                            android:layout_marginLeft="20dp"
                            android:layout_marginRight="20dp"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/subCategoryDropTextView"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/dropdown_border"
                                android:gravity="start|center"
                                android:hint="हवामान अनुकूल तंत्रज्ञान प्रकार"
                                android:paddingEnd="@dimen/padding20"
                                android:paddingStart="@dimen/padding20"
                                android:textColor="@color/heading"
                                android:textSize="@dimen/text14"
                                android:textStyle="normal" />

                            <ImageView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:layout_centerVertical="true"
                                android:layout_marginEnd="@dimen/padding20"
                                android:contentDescription="@string/app_name"
                                android:hint="@color/gray"
                                android:src="@drawable/ic_expand_more_black_24dp"
                                tools:ignore="VectorDrawableCompat" />

                        </RelativeLayout>
                        <LinearLayout
                            android:id="@+id/linLayoutUnit"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:visibility="gone"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="45dp"
                                android:gravity="start|center"
                                android:text="अवलंब केलेल्या तंत्रज्ञानाचे क्षेत्र ( क्षेत्र (हे.) / संख्या )"
                                android:layout_marginTop="@dimen/padding5"
                                android:layout_marginLeft="20dp"
                                android:layout_marginRight="20dp"
                                android:paddingEnd="@dimen/padding20"
                                android:paddingStart="2dp"
                                android:textColor="@color/black"
                                android:textSize="@dimen/text14"
                                android:textStyle="normal" />
                            <EditText
                                android:id="@+id/unitEditText"
                                android:layout_width="match_parent"
                                android:layout_height="45dp"
                                android:background="@drawable/dropdown_border"
                                android:gravity="start|center"
                                android:hint="Enter unit here"
                                android:layout_marginTop="2dp"
                                android:layout_marginLeft="20dp"
                                android:layout_marginRight="20dp"
                                android:paddingEnd="@dimen/padding20"
                                android:paddingStart="@dimen/padding20"
                                android:textColor="@color/heading"
                                android:textSize="@dimen/text14"
                                android:textStyle="normal" />
                        </LinearLayout>
                    </LinearLayout>
                    <LinearLayout
                        android:id="@+id/linlayoutCategory4"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:visibility="gone"
                        android:orientation="vertical">

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/height45"
                            android:layout_marginTop="@dimen/padding5"
                            android:layout_marginLeft="20dp"
                            android:layout_marginRight="20dp"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/farmerGrpListDropTextView"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/dropdown_border"
                                android:gravity="start|center"
                                android:hint="शेतकरी गटाचे नाव निवडा"
                                android:paddingEnd="@dimen/padding20"
                                android:paddingStart="@dimen/padding20"
                                android:textColor="@color/heading"
                                android:textSize="@dimen/text14"
                                android:textStyle="normal" />

                            <ImageView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:layout_centerVertical="true"
                                android:layout_marginEnd="@dimen/padding20"
                                android:contentDescription="@string/app_name"
                                android:hint="@color/gray"
                                android:src="@drawable/ic_expand_more_black_24dp"
                                tools:ignore="VectorDrawableCompat" />

                        </RelativeLayout>
                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/height45"
                            android:layout_marginTop="@dimen/padding5"
                            android:layout_marginLeft="20dp"
                            android:layout_marginRight="20dp"
                            android:visibility="gone"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/discussionTopicDropTextView"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/dropdown_border"
                                android:gravity="start|center"
                                android:hint=" Select Discussion topic"
                                android:paddingEnd="@dimen/padding20"
                                android:paddingStart="@dimen/padding20"
                                android:textColor="@color/heading"
                                android:textSize="@dimen/text14"
                                android:textStyle="normal" />

                            <ImageView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:layout_centerVertical="true"
                                android:layout_marginEnd="@dimen/padding20"
                                android:contentDescription="@string/app_name"
                                android:hint="@color/gray"
                                android:src="@drawable/ic_expand_more_black_24dp"
                                tools:ignore="VectorDrawableCompat" />

                        </RelativeLayout>

                    </LinearLayout>
                    <LinearLayout
                        android:id="@+id/linLayoutFarmerGroupOther"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:visibility="gone"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="45dp"
                            android:gravity="start|center"
                            android:text="शेतकरी गटाचे नाव लिहा"
                            android:layout_marginTop="@dimen/padding5"
                            android:layout_marginLeft="20dp"
                            android:layout_marginRight="20dp"
                            android:paddingEnd="@dimen/padding20"
                            android:paddingStart="2dp"
                            android:textColor="@color/black"
                            android:textSize="@dimen/text14"
                            android:textStyle="normal" />
                        <EditText
                            android:id="@+id/farmerGroupOtherEditText"
                            android:layout_width="match_parent"
                            android:layout_height="45dp"
                            android:background="@drawable/dropdown_border"
                            android:gravity="start|center"
                            android:hint="👉 येथे लिहा"
                            android:layout_marginTop="2dp"
                            android:layout_marginLeft="20dp"
                            android:layout_marginRight="20dp"
                            android:paddingEnd="@dimen/padding20"
                            android:paddingStart="@dimen/padding20"
                            android:textColor="@color/heading"
                            android:textSize="@dimen/text14"
                            android:textStyle="normal" />
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="5dp"
                        android:orientation="vertical">
                        <!-- Tooltip (Initially Hidden) -->
                        <TextView
                            android:id="@+id/tooltipRemark"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="start"
                            android:layout_marginStart="30dp"
                            android:layout_marginBottom="6dp"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="8dp"
                            android:background="@drawable/tooltip_edt_background"
                            android:text="👉 प्रशिक्षणाचे ठिकाण, विषय, प्रमुख उपस्थिती, महत्त्वाची माहिती, online/ offline बैठक इ. विषयी माहिती थोडक्यात लिहावी. 💬"
                            android:textColor="@android:color/black"
                            android:textSize="13sp"
                            android:elevation="4dp"
                            android:visibility="gone" />

                        <EditText
                            android:id="@+id/Remark"
                            android:layout_width="match_parent"
                            android:layout_height="150dp"
                            android:layout_marginLeft="20dp"
                            android:layout_marginRight="20dp"
                            android:background="@drawable/dropdown_border"
                            android:gravity="top|left"
                            android:hint="निरीक्षण लिहा "
                            android:visibility="visible"
                            android:inputType="text"
                            android:textColor="@color/black"
                            android:padding="15dp"
                            android:paddingStart="@dimen/padding10"
                            android:paddingEnd="@dimen/padding10"
                            android:textColorHint="@color/heading"
                            android:textSize="@dimen/text14" />

                        <ImageView
                            android:id="@+id/techImage"
                            android:layout_width="150dp"
                            android:layout_height="150dp"
                            android:layout_gravity="center"
                            android:layout_marginTop="5dp"
                            android:layout_marginBottom="2dp"
                            android:padding="@dimen/padding6"
                            android:src="@drawable/ic_camera_in_out" />
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="फोटो अपलोड करा"
                            android:textStyle="normal"
                            android:gravity="center"
                            android:layout_marginBottom="25dp"
                            android:textColor="@color/gray"
                            android:textSize="14dp"
                            />
                        <Button
                            android:id="@+id/btnSubmitKTAttendance"
                            android:layout_width="300dp"
                            android:layout_height="wrap_content"
                            android:background="@color/colorPrimary"
                            android:padding="5dp"
                            android:layout_marginTop="10dp"
                            android:layout_margin="@dimen/text5"
                            android:layout_gravity="center"
                            android:scaleType="centerCrop"
                            android:text="सादर करा"
                            android:backgroundTint="@color/status_green"
                            android:textSize="@dimen/text16"
                            android:textAllCaps="false"
                            android:textColor="@color/white" />

                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </ScrollView>
    </LinearLayout>


</androidx.constraintlayout.widget.ConstraintLayout>
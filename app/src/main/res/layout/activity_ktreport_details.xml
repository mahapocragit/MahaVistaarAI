    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/primary_green"
        app:title="@string/kt_report_details"
        app:titleTextColor="@android:color/white"
        app:navigationIcon="@drawable/ic_arrow_left_back_24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Custom Layout must be OUTSIDE Toolbar -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:layout_marginEnd="10dp"
        app:layout_constraintTop_toTopOf="@id/toolbar"
        app:layout_constraintBottom_toBottomOf="@id/toolbar">

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/downloadIcon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:src="@drawable/ic_file_download_white"
            android:contentDescription="download" />

        <LinearLayout
            android:id="@+id/hoverLayout"
            android:layout_width="100dp"
            android:layout_height="wrap_content"
            android:layout_toStartOf="@id/downloadIcon"
            android:layout_centerVertical="true"
            android:layout_marginEnd="8dp"
            android:orientation="horizontal"
            android:padding="6dp"
            android:background="@drawable/tooltip_background"
            android:visibility="visible">

            <TextView
                android:id="@+id/hoverMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=" Report"
                android:gravity="center"
                android:textColor="@android:color/white"
                android:textSize="13sp"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp" />
        </LinearLayout>

    </RelativeLayout>

    <!-- Scrollable content -->
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:orientation="vertical"
            android:padding="12dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <Button
                android:id="@+id/btnFarmFieldSchool"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:layout_marginTop="16dp"
                android:text="शेतीशाळा" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvFarmFieldSchool"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:nestedScrollingEnabled="false"
                android:overScrollMode="never" />
            <Button
                android:id="@+id/btnMeeting"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="बैठक" />
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvMeeting"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:overScrollMode="never" />
            <Button
                android:id="@+id/btnVisit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="प्रक्षेत्र भेटी" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvVisit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:overScrollMode="never" />
            <Button
                android:id="@+id/btnTraining"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="प्रशिक्षण" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvTraining"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:overScrollMode="never" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>

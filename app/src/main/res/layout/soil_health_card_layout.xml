<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ScrollView
        android:id="@+id/scrollView3"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/textView29"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/_5sdp"
                android:layout_marginTop="@dimen/_10sdp"
                android:text="Farmer Details" />

            <androidx.cardview.widget.CardView
                android:id="@+id/farmerSoilHealthCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/_5sdp"
                app:cardCornerRadius="@dimen/_10sdp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_weight="7"
                            android:background="@color/card_background_color_figma"
                            android:gravity="center_vertical|end"
                            android:paddingVertical="@dimen/_5sdp"
                            android:paddingEnd="@dimen/_10sdp"
                            android:text="@string/farmer_name" />

                        <TextView
                            android:id="@+id/farmerName"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_weight="3"
                            android:gravity="center_vertical"
                            android:paddingVertical="@dimen/_5sdp"
                            android:text="TextView" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_weight="7"
                            android:background="@color/card_background_color_figma"
                            android:gravity="center_vertical|end"
                            android:paddingVertical="@dimen/_5sdp"
                            android:paddingEnd="@dimen/_10sdp"
                            android:text="@string/soil_health_card_number" />

                        <TextView
                            android:id="@+id/shcNo"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_weight="3"
                            android:gravity="center_vertical"
                            android:paddingVertical="@dimen/_5sdp"
                            android:text="TextView" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_weight="7"
                            android:background="@color/card_background_color_figma"
                            android:gravity="center_vertical|end"
                            android:paddingVertical="@dimen/_5sdp"
                            android:paddingEnd="@dimen/_10sdp"
                            android:text="Village" />

                        <TextView
                            android:id="@+id/surveyNumber"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_weight="3"
                            android:gravity="center_vertical"
                            android:paddingVertical="@dimen/_5sdp"
                            android:text="TextView" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_weight="7"
                            android:background="@color/card_background_color_figma"
                            android:gravity="center_vertical|end"
                            android:paddingVertical="@dimen/_5sdp"
                            android:paddingEnd="@dimen/_10sdp"
                            android:text="Taluka" />

                        <TextView
                            android:id="@+id/farmSize"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_weight="3"
                            android:gravity="center_vertical"
                            android:paddingVertical="@dimen/_5sdp"
                            android:text="TextView" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_weight="7"
                            android:background="@color/card_background_color_figma"
                            android:gravity="center_vertical|end"
                            android:paddingVertical="@dimen/_5sdp"
                            android:paddingEnd="@dimen/_10sdp"
                            android:text="District" />

                        <TextView
                            android:id="@+id/farmSize1"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_weight="3"
                            android:gravity="center_vertical"
                            android:paddingVertical="@dimen/_5sdp"
                            android:text="TextView" />
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <TextView
                android:id="@+id/textView28"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/_5sdp"
                android:text="Soil test results" />

            <androidx.cardview.widget.CardView
                android:id="@+id/farmerSoilHealthCard12"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/_5sdp"
                app:cardCornerRadius="@dimen/_10sdp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <TableLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:stretchColumns="*">

                    <TableRow
                        android:background="@color/card_background_color_figma"
                        android:padding="@dimen/_6sdp">

                        <TextView
                            android:text="Test parameter"
                            android:textStyle="bold" />

                        <TextView
                            android:text="Value"
                            android:textStyle="bold" />

                        <TextView
                            android:text="Unit"
                            android:textStyle="bold" />

                        <TextView
                            android:text="Rating"
                            android:textStyle="bold" />
                    </TableRow>

                    <TableRow android:padding="@dimen/_6sdp">

                        <TextView android:text="Nitrogen (N)" />

                        <TextView android:text="32.13" />

                        <TextView android:text="Kg/Ha" />

                        <TextView android:text="✅" />
                    </TableRow>

                    <TableRow android:padding="@dimen/_6sdp">

                        <TextView android:text="Phosphorus (P)" />

                        <TextView android:text="368.48" />

                        <TextView android:text="ppm" />

                        <TextView android:text="✅" />
                    </TableRow>

                    <TableRow android:padding="@dimen/_6sdp">

                        <TextView android:text="Organic carbon (OC)" />

                        <TextView android:text="368.48" />

                        <TextView android:text="ppm" />

                        <TextView
                            android:gravity=""
                            android:text="⚠️" />
                    </TableRow>
                </TableLayout>
            </androidx.cardview.widget.CardView>

            <TextView
                android:id="@+id/textView30"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/_5sdp"
                android:text="Fertilizer recommendation" />

            <androidx.cardview.widget.CardView
                android:id="@+id/farmerSoilHealthCard1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/_5sdp"
                app:cardCornerRadius="@dimen/_10sdp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <TableLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:stretchColumns="*">

                    <TableRow
                        android:background="@color/card_background_color_figma"
                        android:padding="@dimen/_6sdp">

                        <TextView
                            android:layout_gravity="center_vertical"
                            android:text="Crop Variety"
                            android:textStyle="bold" />

                        <TextView
                            android:text="Organic \nFertilizers"
                            android:textStyle="bold" />

                        <TextView
                            android:text="Bio \nFertilizers"
                            android:textStyle="bold" />

                        <TextView
                            android:text="Qty \n g/kg of seed"
                            android:textStyle="bold" />
                    </TableRow>

                    <TableRow android:padding="@dimen/_6sdp">

                        <TextView android:text="Nitrogen (N)" />

                        <TextView android:text="32.13" />

                        <TextView android:text="Kg/Ha" />

                        <TextView android:text="✅" />
                    </TableRow>

                    <TableRow android:padding="@dimen/_6sdp">

                        <TextView android:text="Phosphorus (P)" />

                        <TextView android:text="368.48" />

                        <TextView android:text="ppm" />

                        <TextView android:text="✅" />
                    </TableRow>

                    <TableRow android:padding="@dimen/_6sdp">

                        <TextView android:text="Organic carbon (OC)" />

                        <TextView android:text="368.48" />

                        <TextView android:text="ppm" />

                        <TextView
                            android:gravity=""
                            android:text="⚠️" />
                    </TableRow>
                </TableLayout>
            </androidx.cardview.widget.CardView>

            <LinearLayout
                android:id="@+id/linearLayout"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginHorizontal="5dp"
                android:layout_marginVertical="@dimen/_6sdp"
                android:orientation="horizontal"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <TextView
                    android:id="@+id/previousSevenDayTV"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginVertical="5dp"
                    android:layout_marginStart="5dp"
                    android:layout_weight="1"
                    android:background="@drawable/shape_right"
                    android:elevation="5dp"
                    android:gravity="center"
                    android:text="Fertilizer Combination 1"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/nextSevenDayTV"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginVertical="5dp"
                    android:layout_marginEnd="5dp"
                    android:layout_weight="1"
                    android:background="@drawable/shape_left"
                    android:elevation="5dp"
                    android:gravity="center"
                    android:text="Fertilizer Combination 2"
                    android:textColor="@color/white"
                    android:textStyle="bold" />


            </LinearLayout>

            <androidx.cardview.widget.CardView
                android:id="@+id/farmerSoilHealthCard112"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/_5sdp"
                app:cardCornerRadius="@dimen/_10sdp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <TableLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:stretchColumns="*">

                    <TableRow
                        android:background="@color/card_background_color_figma"
                        android:padding="@dimen/_6sdp">

                        <TextView
                            android:background="@color/card_background_color_figma"
                            android:text="Urea"
                            android:textStyle="bold" />

                        <TextView
                            android:background="@color/card_background_color_figma"
                            android:text="Single \nSuperphosphate"
                            android:textStyle="bold" />

                        <TextView
                            android:background="@color/card_background_color_figma"
                            android:text="Potassium Chloride (Muriate \nof Potash) (Granular)"
                            android:textStyle="bold" />
                    </TableRow>

                    <TableRow android:padding="@dimen/_6sdp">

                        <TextView android:text="546 \nkg/ha" />

                        <TextView android:text="32.13" />

                        <TextView android:text="Kg/Ha" />
                    </TableRow>

                    <TableRow android:padding="@dimen/_6sdp">

                        <TextView android:text="546 \nkg/ha" />

                        <TextView android:text="368.48" />

                        <TextView android:text="ppm" />
                    </TableRow>

                    <TableRow android:padding="@dimen/_6sdp">

                        <TextView android:text="546 \nkg/ha" />

                        <TextView android:text="368.48" />

                        <TextView android:text="ppm" />
                    </TableRow>
                </TableLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
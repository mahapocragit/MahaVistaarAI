<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".activity.CommingSoonActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:backgroundTint="@color/status_green"
        android:theme="@style/AppTheme.AppBarOverlay">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="@dimen/height40"
            android:backgroundTint="@color/transparent_green"
            android:background="?attr/colorPrimary"
            app:popupTheme="@style/AppTheme.AppBarOverlay">
            <ImageView
                android:id="@+id/imgBackArrow"
                android:layout_width="@dimen/height25"
                android:layout_height="@dimen/height25"
                android:layout_gravity="left"
                android:layout_marginRight="@dimen/height20"
                android:src="@drawable/ic_baseline_arrow_back_24" />
            <ImageView
                android:id="@+id/logoXmarks"
                android:layout_width="@dimen/height40"
                android:layout_height="@dimen/height40"
                android:adjustViewBounds="true"
                android:layout_gravity="center"
                android:src="@drawable/pocra_logo" />
            <ImageView
                android:id="@+id/imgCallIcon"
                android:layout_width="@dimen/height25"
                android:layout_height="@dimen/height25"
                android:layout_gravity="right"
                android:layout_marginRight="@dimen/height20"
                android:src="@drawable/phone_call_icon" />

        </androidx.appcompat.widget.Toolbar>
    </com.google.android.material.appbar.AppBarLayout>

    <TextView
        android:id="@+id/textNotificationMsg"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/comming_Soon"
        android:textColor="@color/status_green"
        android:layout_centerInParent="true"
        android:layout_centerHorizontal="true"
        android:gravity="center"
        android:textStyle="bold"
        android:textSize="25dp">

    </TextView>
</RelativeLayout>
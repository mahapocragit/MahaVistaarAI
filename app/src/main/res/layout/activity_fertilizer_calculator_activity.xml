<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_marginBottom="5dp"
    app:layout_behavior="@string/appbar_scrolling_view_behavior">

<RelativeLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    tools:context=".activity.FertilizerCalculatorActivity">

    <include
        android:id="@+id/relativeLayoutTopBar"
        layout="@layout/layout_toolbar" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="@dimen/height50"
            android:layout_marginHorizontal="@dimen/height10"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal">

                <include
                    android:id="@+id/sowingInfoLayout"
                    layout="@layout/sowing_date_layout"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="@dimen/height5"
                    android:text="@string/plot_size"
                    android:textColor="@color/text_black_light"
                    android:textSize="@dimen/text14"
                    android:textStyle="bold"></TextView>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:layout_gravity="center"
                    android:background="@color/bg_green" />

            </LinearLayout>

        <LinearLayout
            android:id="@+id/lnr_plot_size"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginLeft="10dp"
            android:visibility="visible"
            android:layout_marginRight="20dp"
            android:layout_marginTop="@dimen/padding5"
            android:weightSum="2">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginRight="@dimen/height10"
                android:layout_marginLeft="@dimen/height10"
                android:gravity="center"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_marginLeft="2dp"
                    android:layout_marginRight="@dimen/height5"
                    android:background="@drawable/text_bg_brown"
                    android:textColor="@color/black"
                    android:gravity="center"
                    android:layout_weight="0.5"
                    android:text="@string/acre"
                    android:textSize="@dimen/text12"
                    android:textStyle="bold">
                </TextView>

                <EditText
                    android:id="@+id/edtAcre"
                    android:layout_width="wrap_content"
                    android:layout_height="60dp"
                    android:background="@drawable/login_edit_bg"
                    android:digits="@string/numeric"
                    android:elevation="8dp"
                    android:gravity="center|start"
                    android:hint=""
                    android:inputType="number"
                    android:textAlignment="center"
                    android:clickable="false"
                    android:maxLength="2"
                    android:layout_weight="0.5"
                    android:maxLines="1"
                    android:paddingStart="@dimen/padding20"
                    android:paddingEnd="@dimen/padding20"
                    android:textColor="@color/black"
                    android:textColorHint="@color/text_black"
                    android:textSize="@dimen/text12" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginRight="@dimen/height10"
                android:layout_marginLeft="@dimen/height10"
                android:gravity="center"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_marginLeft="2dp"
                    android:layout_marginRight="@dimen/height5"
                    android:background="@drawable/text_bg_brown"
                    android:textColor="@color/black"
                    android:gravity="center"
                    android:layout_weight="0.5"
                    android:text="@string/guntha"
                    android:textSize="@dimen/text12"
                    android:textStyle="bold">

                </TextView>

                <EditText
                    android:id="@+id/edtGuntha"
                    android:layout_width="wrap_content"
                    android:layout_height="60dp"
                    android:background="@drawable/login_edit_bg"
                    android:digits="@string/numeric"
                    android:elevation="8dp"
                    android:gravity="center|start"
                    android:hint=""
                    android:inputType="number"
                    android:textAlignment="center"
                    android:clickable="false"
                    android:maxLength="2"
                    android:layout_weight="0.5"
                    android:maxLines="1"
                    android:paddingStart="@dimen/padding20"
                    android:paddingEnd="@dimen/padding20"
                    android:textColor="@color/black"
                    android:textColorHint="@color/text_black"
                    android:textSize="@dimen/text12" />

            </LinearLayout>

        </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:gravity="center"
                android:visibility="gone"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/plus_button_img"></ImageView>

                <TextView
                    android:id="@+id/plut_count_area"
                    android:layout_width="100dp"
                    android:layout_height="40dp"
                    android:layout_marginLeft="@dimen/height5"
                    android:layout_marginRight="@dimen/height5"
                    android:background="@drawable/layout_button_bg"
                    android:gravity="center"
                    android:text="3"
                    android:textColor="@color/text_black_light"
                    android:textSize="@dimen/text14"
                    android:textStyle="bold"></TextView>


            </LinearLayout>

            <RadioGroup
                android:id="@+id/radioGroup1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/padding25"
                android:visibility="gone"
                android:layout_marginTop="@dimen/padding5"
                android:orientation="horizontal">

                <RadioButton
                    android:id="@+id/transgenderRadioButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="@dimen/padding20"
                    android:text="@string/hectare" />

                <RadioButton
                    android:id="@+id/maleRadioButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/acre" />

                <RadioButton
                    android:id="@+id/femaleRadioButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="@dimen/padding20"
                    android:text="@string/guntha" />



            </RadioGroup>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/height5"
                android:text="@string/do_you_have_soil_test_report"
                android:textColor="@color/text_black_light"
                android:textSize="@dimen/text14"
                android:textStyle="bold"></TextView>

            <RadioGroup
                android:id="@+id/radioGroup2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/padding25"
                android:layout_marginTop="@dimen/padding5"
                android:orientation="horizontal">

                <RadioButton
                    android:id="@+id/yesRadioButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/black"
                    android:textStyle="bold"
                    android:checked="true"
                    android:text="@string/yes" />

                <RadioButton
                    android:id="@+id/noRadioButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/black"
                    android:textStyle="bold"
                    android:checked="false"
                    android:layout_marginLeft="@dimen/padding20"
                    android:text="@string/no" />

            </RadioGroup>

            <LinearLayout
                android:id="@+id/lnr_soil_test_no"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="visible"
                android:orientation="vertical">


            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/height5"
                android:paddingBottom="@dimen/height5"
                android:text="@string/soil_test_report"
                android:textColor="@color/text_black_light"
                android:textSize="@dimen/text14"
                android:textStyle="bold"></TextView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/height5"
                android:text="@string/survey_number"
                android:textColor="@color/text_black_light"
                android:textSize="@dimen/text14"
                android:textStyle="bold"></TextView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:orientation="horizontal">
                <EditText
                    android:id="@+id/edtSurveyNo"
                    android:layout_width="wrap_content"
                    android:layout_height="60dp"
                    android:background="@drawable/login_edit_bg"
                    android:digits="@string/numeric"
                    android:gravity="center|start"
                    android:elevation="8dp"
                    android:layout_marginLeft="2dp"
                    android:layout_marginRight="20dp"
                    android:textSize="@dimen/text12"
                    android:layout_weight="1.5"
                    android:textColorHint="@color/text_black"
                    android:textColor="@color/black"
                    android:inputType="number"
                    android:maxLength="10"
                    android:maxLines="1"
                    android:paddingStart="@dimen/padding20"
                    android:paddingEnd="@dimen/padding20" />

                <TextView
                    android:id="@+id/fetchNPKTv"
                    android:layout_width="100dp"
                    android:layout_height="40dp"
                    android:layout_marginLeft="2dp"
                    android:layout_marginRight="@dimen/height20"
                    android:layout_weight="0.5"
                    android:background="@drawable/btn_bg"
                    android:gravity="center"
                    android:paddingLeft="5dp"
                    android:text="@string/fetch_data"
                    android:textColor="@color/white"
                    android:textSize="@dimen/text14"
                    android:textStyle="bold">

                </TextView>
            </LinearLayout>

            </LinearLayout>
            <LinearLayout
                android:id="@+id/lnr_soil_test_yes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                >

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/height5"
                android:text="@string/your_N_P_K_values"
                android:textColor="@color/line"
                android:textSize="@dimen/text14"
                android:textStyle="bold">
            </TextView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="@dimen/padding5"
                android:weightSum="3">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:gravity="center"
                        android:layout_marginLeft="2dp"
                        android:layout_marginRight="@dimen/height5"
                        android:background="@drawable/text_bg_brown"
                        android:padding="@dimen/height10"
                        android:textColor="@color/black"
                        android:paddingLeft="5dp"
                        android:text="@string/nitrogen"
                        android:textSize="@dimen/text12"
                        android:textStyle="bold">

                    </TextView>

                    <EditText
                        android:id="@+id/edNitrogen"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:layout_marginLeft="20dp"
                        android:layout_marginRight="20dp"
                        android:background="@drawable/login_edit_bg"
                        android:digits="@string/numeric"
                        android:elevation="8dp"
                        android:gravity="center|start"
                        android:textAlignment="center"
                        android:hint=""
                        android:inputType="number"
                        android:maxLength="3"
                        android:maxLines="1"
                        android:paddingStart="@dimen/padding20"
                        android:paddingEnd="@dimen/padding20"
                        android:textColor="@color/black"
                        android:textColorHint="@color/text_black"
                        android:textSize="@dimen/text12" />


                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:gravity="center"
                        android:layout_marginLeft="2dp"
                        android:padding="@dimen/height10"
                        android:layout_marginRight="@dimen/height5"
                        android:background="@drawable/text_bg_brown"
                        android:textColor="@color/black"
                        android:paddingLeft="5dp"
                        android:text="@string/phosphorus"
                        android:textSize="@dimen/text12"
                        android:textStyle="bold">

                    </TextView>

                    <EditText
                        android:id="@+id/edPhosphorus"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:layout_marginLeft="20dp"
                        android:layout_marginRight="20dp"
                        android:background="@drawable/login_edit_bg"
                        android:digits="@string/numeric"
                        android:elevation="8dp"
                        android:gravity="center|start"
                        android:textAlignment="center"
                        android:hint=""
                        android:inputType="number"
                        android:maxLength="3"
                        android:maxLines="1"
                        android:paddingStart="@dimen/padding20"
                        android:paddingEnd="@dimen/padding20"
                        android:textColor="@color/black"
                        android:textColorHint="@color/text_black"
                        android:textSize="@dimen/text12" />


                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:gravity="center"
                        android:layout_marginLeft="2dp"
                        android:padding="@dimen/height10"
                        android:layout_marginRight="@dimen/height5"
                        android:background="@drawable/text_bg_brown"
                        android:textColor="@color/black"
                        android:paddingLeft="5dp"
                        android:text="@string/potassium"
                        android:textSize="@dimen/text12"
                        android:textStyle="bold">

                    </TextView>

                    <EditText
                        android:id="@+id/edPotassium"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:layout_marginLeft="20dp"
                        android:layout_marginRight="20dp"
                        android:background="@drawable/login_edit_bg"
                        android:digits="@string/numeric"
                        android:elevation="8dp"
                        android:gravity="center|start"
                        android:textAlignment="center"
                        android:hint=""
                        android:inputType="number"
                        android:maxLength="3"
                        android:maxLines="1"
                        android:paddingStart="@dimen/padding20"
                        android:paddingEnd="@dimen/padding20"
                        android:textColor="@color/black"
                        android:textColorHint="@color/text_black"
                        android:textSize="@dimen/text12" />


                </LinearLayout>




            </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="@dimen/height5"
                    android:text="@string/hw_much_fym_used"
                    android:textColor="@color/line"
                    android:textSize="@dimen/text14"
                    android:textStyle="bold">
                </TextView>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="@dimen/padding5"
                    android:weightSum="2">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:gravity="center"
                            android:padding="@dimen/height10"
                            android:background="@drawable/text_bg_brown"
                            android:textColor="@color/black"
                            android:paddingLeft="5dp"
                            android:text="@string/FYM"
                            android:textSize="@dimen/text12"
                            android:textStyle="bold">

                        </TextView>

                        <EditText
                            android:id="@+id/edtFYM"
                            android:layout_width="match_parent"
                            android:layout_height="60dp"
                            android:layout_marginLeft="150dp"
                            android:layout_marginRight="150dp"
                            android:background="@drawable/login_edit_bg"
                            android:digits="@string/numeric"
                            android:elevation="8dp"
                            android:gravity="center|start"
                            android:textAlignment="center"
                            android:hint=""
                            android:inputType="number"
                            android:maxLength="2"
                            android:maxLines="1"
                            android:paddingStart="@dimen/padding20"
                            android:paddingEnd="@dimen/padding20"
                            android:textColor="@color/black"
                            android:textColorHint="@color/text_black"
                            android:textSize="@dimen/text12" />


                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:visibility="gone"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="2dp"
                            android:background="@drawable/btn_bg"
                            android:paddingLeft="5dp"
                            android:text="@string/Target_Yield"
                            android:textColor="@color/white"
                            android:textSize="@dimen/text14"
                            android:textStyle="bold">

                        </TextView>

                        <EditText
                            android:id="@+id/edtTargetYield"
                            android:layout_width="match_parent"
                            android:layout_height="60dp"
                            android:layout_marginLeft="20dp"
                            android:layout_marginRight="20dp"
                            android:background="@drawable/login_edit_bg"
                            android:digits="@string/numeric"
                            android:elevation="8dp"
                            android:gravity="center|start"
                            android:hint=""
                            android:inputType="number"
                            android:maxLength="10"
                            android:maxLines="1"
                            android:paddingStart="@dimen/padding20"
                            android:paddingEnd="@dimen/padding20"
                            android:textColorHint="@color/text_black"
                            android:textSize="@dimen/text12" />


                    </LinearLayout>

                </LinearLayout>



            </LinearLayout>

            <LinearLayout
                android:id="@+id/lnr_npk_fetch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginLeft="20dp"
                android:visibility="visible"
                android:layout_marginRight="20dp"
                android:layout_marginTop="@dimen/padding5"
                android:weightSum="3">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:layout_marginLeft="2dp"
                        android:background="@drawable/btn_bg"
                        android:gravity="center"
                        android:layout_weight="0.5"
                        android:text="N"
                        android:textColor="@color/white"
                        android:textSize="@dimen/text14"
                        android:textStyle="bold">

                    </TextView>

                    <EditText
                        android:id="@+id/edNitrogen1"
                        android:layout_width="wrap_content"
                        android:layout_height="60dp"
                        android:background="@drawable/login_edit_bg"
                        android:digits="@string/numeric"
                        android:elevation="8dp"
                        android:gravity="center|start"
                        android:hint=""
                        android:inputType="number"
                        android:clickable="false"
                        android:maxLength="10"
                        android:layout_weight="0.5"
                        android:maxLines="1"
                        android:paddingStart="@dimen/padding20"
                        android:paddingEnd="@dimen/padding20"
                        android:textColor="@color/black"
                        android:textColorHint="@color/text_black"
                        android:textSize="@dimen/text12" />

                </LinearLayout>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:layout_marginLeft="2dp"
                        android:background="@drawable/btn_bg"
                        android:gravity="center"
                        android:layout_weight="0.5"
                        android:text="P"
                        android:textColor="@color/white"
                        android:textSize="@dimen/text14"
                        android:textStyle="bold">

                    </TextView>

                    <EditText
                        android:id="@+id/edPhosphorus1"
                        android:layout_width="wrap_content"
                        android:layout_height="60dp"
                        android:background="@drawable/login_edit_bg"
                        android:digits="@string/numeric"
                        android:elevation="8dp"
                        android:gravity="center|start"
                        android:hint=""
                        android:inputType="number"
                        android:clickable="false"
                        android:maxLength="10"
                        android:layout_weight="0.5"
                        android:maxLines="1"
                        android:paddingStart="@dimen/padding20"
                        android:paddingEnd="@dimen/padding20"
                        android:textColor="@color/black"
                        android:textColorHint="@color/text_black"
                        android:textSize="@dimen/text12" />

                </LinearLayout>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:layout_marginLeft="2dp"
                        android:background="@drawable/btn_bg"
                        android:gravity="center"
                        android:layout_weight="0.5"
                        android:text="K"
                        android:textColor="@color/white"
                        android:textSize="@dimen/text14"
                        android:textStyle="bold">

                    </TextView>

                    <EditText
                        android:id="@+id/edPotassium1"
                        android:layout_width="wrap_content"
                        android:layout_height="60dp"
                        android:background="@drawable/login_edit_bg"
                        android:digits="@string/numeric"
                        android:elevation="8dp"
                        android:gravity="center|start"
                        android:hint=""
                        android:inputType="number"
                        android:clickable="false"
                        android:maxLength="10"
                        android:layout_weight="0.5"
                        android:maxLines="1"
                        android:paddingStart="@dimen/padding20"
                        android:paddingEnd="@dimen/padding20"
                        android:textColor="@color/black"
                        android:textColorHint="@color/text_black"
                        android:textSize="@dimen/text12" />

                </LinearLayout>


            </LinearLayout>

            <LinearLayout
                android:id="@+id/linLayoutButton"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_above="@+id/footer"
                android:layout_gravity="end"
                android:gravity="end"
                android:layout_margin="5dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/calculateTv"
                    android:layout_width="@dimen/height100"
                    android:layout_height="40dp"
                    android:layout_marginRight="@dimen/height10"
                    android:background="@drawable/green_bg_gradient"
                    android:gravity="center"
                    android:padding="@dimen/height5"
                    android:text="@string/calculate"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    android:textSize="@dimen/text16" />

                <TextView
                    android:id="@+id/restTv"
                    android:layout_width="@dimen/height100"
                    android:layout_height="40dp"
                    android:layout_marginRight="@dimen/height10"
                    android:background="@drawable/yellow_bg_gradient"
                    android:gravity="center"
                    android:padding="@dimen/height5"
                    android:text="@string/reset"
                    android:textColor="@color/colorAccent"
                    android:textSize="@dimen/text16"
                    android:textStyle="bold" />


            </LinearLayout>
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/black" />


                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:layout_above="@+id/footer"
                    android:layout_gravity="end"
                    android:gravity="end"
                    android:layout_margin="5dp"
                    android:layout_weight="1"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/availableOptionTv"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:layout_marginRight="@dimen/height10"
                        android:background="@drawable/green_bg_gradient"
                        android:gravity="center"
                        android:layout_weight="0.5"
                        android:padding="@dimen/height5"
                        android:text="@string/available_option"
                        android:visibility="invisible"
                        android:textColor="@color/white"
                        android:textSize="@dimen/text16" />

                    <TextView
                        android:id="@+id/selectedOptionTv"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:layout_marginRight="@dimen/height10"
                        android:layout_weight="0.5"

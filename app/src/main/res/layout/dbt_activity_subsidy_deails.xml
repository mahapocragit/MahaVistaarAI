<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

<!--    <androidx.cardview.widget.CardView-->
<!--        android:layout_width="match_parent"-->
<!--        android:layout_height="wrap_content"-->
<!--        android:layout_marginLeft="@dimen/padding10"-->
<!--        android:layout_marginRight="@dimen/padding20"-->
<!--        android:layout_marginTop="@dimen/padding10"-->
<!--        app:cardElevation="@dimen/padding3"-->
<!--        android:padding="5dp"-->
<!--        app:cardMaxElevation="@dimen/padding1"-->
<!--        app:cardUseCompatPadding="true">-->

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                        <TextView
                            android:id="@+id/subsidyYear"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginRight="@dimen/height10"
                            android:layout_weight="1"
                            android:layout_marginLeft="@dimen/height10"
                            android:text="@string/market_term"
                            android:textSize="14sp"
                            android:padding="1dp"
                            android:textColor="@color/colorPrimary" />
                        <TextView
                            android:id="@+id/maxSubsidyPercentage"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginRight="@dimen/height10"
                            android:layout_marginLeft="@dimen/height10"
                            android:text="@string/market_percentage"
                            android:textSize="14sp"
                            android:padding="1dp"
                            android:textColor="@color/colorPrimary" />

                        <TextView
                            android:id="@+id/maxSubsidyAmount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginRight="@dimen/height10"
                            android:layout_marginLeft="@dimen/height10"
                            android:text="@string/market_amount"
                            android:textSize="14sp"
                            android:padding="1dp"
                            android:textColor="@color/colorPrimary"
                            />

                        <TextView
                            android:id="@+id/note"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginRight="@dimen/height10"
                            android:layout_marginLeft="@dimen/height10"
                            android:text="@string/notes"
                            android:textSize="14sp"
                            android:padding="1dp"
                            android:textColor="@color/colorPrimary" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/subsidyYearValue"
                            android:text="SO0000139"
                            android:layout_weight="1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="@dimen/height10"
                            android:gravity="center|left"
                            android:textSize="14sp"
                            android:padding="1dp"
                            android:textColor="@color/black" />

                        <TextView
                            android:id="@+id/maxSubsidyPercentageValue"
                            android:text="SO0000139"
                            android:layout_weight="1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="@dimen/height10"
                            android:gravity="center|left"
                            android:textSize="14sp"
                            android:padding="1dp"
                            android:textColor="@color/black" />

                        <TextView
                            android:id="@+id/maxSubsidyAmountValue"
                            android:text="SO0000139"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="@dimen/height10"
                            android:gravity="center|left"
                            android:textSize="14sp"
                            android:padding="1dp"
                            android:textColor="@color/black" />


                        <TextView
                            android:id="@+id/noteValue"
                            android:text="SO0000139"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="@dimen/height10"
                            android:gravity="center|left"
                            android:textSize="14sp"
                            android:padding="1dp"
                            android:textColor="@color/black" />

                    </LinearLayout>

        </LinearLayout>

<!--    </androidx.cardview.widget.CardView>-->


</LinearLayout>
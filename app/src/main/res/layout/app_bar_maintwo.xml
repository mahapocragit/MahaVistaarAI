<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:backgroundTint="@color/status_green"
        android:theme="@style/AppTheme.AppBarOverlay">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/actionbar_color_figma"
            app:popupTheme="@style/AppTheme.AppBarOverlay">

            <com.mikhaellopez.circularimageview.CircularImageView
                android:id="@+id/FarmerlogoXmarks"
                android:layout_width="@dimen/height50"
                android:layout_height="@dimen/height50"
                android:layout_gravity="start"
                android:scaleType="centerInside"
                android:adjustViewBounds="true"
                android:src="@drawable/pocra_farmer_logo" />

            <com.mikhaellopez.circularimageview.CircularImageView
                android:id="@+id/logoXmarks"
                android:layout_width="@dimen/height50"
                android:layout_height="@dimen/height50"
                android:layout_gravity="start"
                android:scaleType="centerInside"
                android:layout_marginStart="@dimen/_16sdp"
                android:adjustViewBounds="true"
                android:src="@drawable/pocra_latest_logo" />

            <ImageView
                android:id="@+id/imgCallIcon"
                android:layout_width="@dimen/_24sdp"
                android:layout_height="@dimen/_24sdp"
                android:layout_gravity="right"
                android:layout_marginRight="@dimen/_10sdp"
                android:padding="@dimen/_2sdp"
                android:src="@drawable/call" />

            <ImageView
                android:id="@+id/imgLangChange"
                android:layout_width="@dimen/_24sdp"
                android:layout_height="@dimen/_24sdp"
                android:layout_gravity="right"
                android:layout_marginRight="@dimen/_10sdp"
                android:padding="@dimen/_2sdp"
                android:src="@drawable/language" />

            <ImageView
                android:id="@+id/imgNotification"
                android:layout_width="@dimen/_24sdp"
                android:layout_height="@dimen/_24sdp"
                android:layout_gravity="right"
                android:layout_marginRight="@dimen/_10sdp"
                android:padding="@dimen/_2sdp"
                android:src="@drawable/notify" />
        </androidx.appcompat.widget.Toolbar>
    </com.google.android.material.appbar.AppBarLayout>

    <include layout="@layout/content_maintwo" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
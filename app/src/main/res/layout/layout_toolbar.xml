<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:background="@color/transparent_green"
    android:layout_height="wrap_content">

    <RelativeLayout
        android:id="@+id/relativeLayoutToolbar"
        android:layout_width="match_parent"
        android:layout_height="45dp">
        <ImageView
            android:id="@+id/imgBackArrow"
            android:layout_width="@dimen/height25"
            android:layout_height="@dimen/height25"
            android:layout_gravity="left"
            android:visibility="gone"
            android:layout_marginTop="10dp"
            android:layout_marginLeft="15dp"
            android:layout_marginRight="@dimen/height20"
            android:src="@drawable/ic_baseline_arrow_back_24" />
        <ImageView
            android:id="@+id/imageViewHeaderBack"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_centerVertical="true"
            android:layout_marginLeft="15dp"
            android:padding="4dp"
            android:visibility="gone"
            app:srcCompat="@drawable/ic_left_arrow"
            tools:ignore="VectorDrawableCompat" />
        <ImageView
            android:id="@+id/imageMenushow"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_centerVertical="true"
            android:layout_marginLeft="15dp"
            android:padding="4dp"
            android:visibility="gone"
            app:srcCompat="@drawable/ic_baseline_home_24"
            tools:ignore="VectorDrawableCompat" />

        <TextView
            android:id="@+id/textViewHeaderTitle"
            android:layout_width="wrap_content"
            android:layout_height="45dp"
            android:layout_centerHorizontal="true"
            android:gravity="center"
            android:textSize="20dp"
            android:text="Title"
            android:textStyle="bold"
            android:textAlignment="center"
            android:textColor="@color/status_green" />

        <TableRow
            android:layout_width="match_parent"
            android:layout_marginTop="2dp"
            android:layout_height="1.5dp"
            android:layout_below="@id/textViewHeaderTitle"
            android:background="@color/white"
            android:visibility="gone"/>
        <ImageView
            android:id="@+id/imageViewFilterMenu"
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"
            android:layout_marginRight="20dp"
            android:padding="1dp"
            android:visibility="gone"
            app:srcCompat="@drawable/filter"
            tools:ignore="VectorDrawableCompat" />
        <ImageView
            android:id="@+id/imageViewCall"
            android:layout_width="28dp"
            android:layout_height="25dp"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"
            android:layout_marginRight="20dp"
            android:padding="1dp"
            android:visibility="gone"
            app:srcCompat="@drawable/ic_baseline_call_24"
            tools:ignore="VectorDrawableCompat" />
        <ImageView
            android:id="@+id/imageViewDeleteMenu"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"
            android:layout_marginRight="20dp"
            android:padding="1dp"
            android:visibility="gone"
            app:srcCompat="@drawable/ic_delete_forever_white_24dp"
            tools:ignore="VectorDrawableCompat" />
        <TextView
            android:id="@+id/textViewSkip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentRight="true"
            android:textColor="@color/white"
            android:layout_centerVertical="true"
            android:layout_marginRight="20dp"
            android:textSize="15dp"
            android:visibility="gone"
            android:padding="1dp"
            android:text="SKIP"/>

    </RelativeLayout>

    <View
        android:id="@+id/view1"
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:layout_below="@+id/relativeLayoutToolbar"
        android:background="#350352"></View>
</RelativeLayout>
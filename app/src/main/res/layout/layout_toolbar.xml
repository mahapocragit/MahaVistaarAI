<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="@dimen/_40sdp"
    android:background="@color/actionbar_color_figma">

    <RelativeLayout
        android:id="@+id/relativeLayoutToolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="@dimen/_38sdp">

        <ImageView
            android:id="@+id/imgBackArrow"
            android:layout_width="@dimen/height25"
            android:layout_height="@dimen/height25"
            android:layout_gravity="left"
            android:layout_margin="@dimen/_10sdp"
            android:src="@drawable/ic_left_arrow"
            android:visibility="gone"
            app:tint="@color/white" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="45dp"
            android:layout_marginStart="@dimen/_10sdp"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/imageViewHeaderBack"
                android:layout_width="30dp"
                android:layout_height="45dp"
                android:padding="4dp"
                android:visibility="gone"
                app:srcCompat="@drawable/ic_left_arrow"
                tools:ignore="VectorDrawableCompat" />

            <ImageView
                android:id="@+id/imageMenushow"
                android:layout_width="30dp"
                android:layout_height="45dp"
                android:layout_marginLeft="15dp"
                android:padding="4dp"
                android:visibility="gone"
                app:srcCompat="@drawable/ic_baseline_home_24"
                app:tint="@color/white"
                tools:ignore="VectorDrawableCompat" />
        </LinearLayout>

        <TextView
            android:id="@+id/textViewHeaderTitle"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/_40sdp"
            android:layout_centerHorizontal="true"
            android:gravity="center"
            android:text="Title"
            android:textAlignment="center"
            android:textColor="@color/white"
            android:textSize="@dimen/_14sdp"
            android:textStyle="bold" />

        <TableRow
            android:layout_width="match_parent"
            android:layout_height="1.5dp"
            android:layout_below="@id/textViewHeaderTitle"
            android:layout_marginTop="2dp"
            android:background="@color/white"
            android:visibility="gone" />

        <ImageView
            android:id="@+id/imageViewFilterMenu"
            android:layout_width="@dimen/_20sdp"
            android:layout_height="@dimen/_20sdp"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"
            android:layout_marginRight="20dp"
            android:padding="1dp"
            app:tint="@color/white"
            android:visibility="gone"
            app:srcCompat="@drawable/filter"
            tools:ignore="VectorDrawableCompat" />

        <ImageView
            android:id="@+id/imageViewCall"
            android:layout_width="28dp"
            android:layout_height="25dp"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"
            android:layout_marginRight="20dp"
            android:padding="1dp"
            android:visibility="gone"
            app:srcCompat="@drawable/ic_baseline_call_24"
            tools:ignore="VectorDrawableCompat" />

        <ImageView
            android:id="@+id/imageViewDeleteMenu"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"
            android:layout_marginRight="20dp"
            android:padding="1dp"
            android:visibility="gone"
            app:srcCompat="@drawable/ic_delete_forever_white_24dp"
            tools:ignore="VectorDrawableCompat" />

        <TextView
            android:id="@+id/textViewSkip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"
            android:layout_marginRight="20dp"
            android:padding="1dp"
            android:text="SKIP"
            android:textColor="@color/white"
            android:textSize="15dp"
            android:visibility="gone" />

    </RelativeLayout>
</RelativeLayout>
<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_marginTop="?attr/actionBarSize"
    tools:showIn="@layout/app_bar_main">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:layout_marginBottom="@dimen/_70sdp"
        android:scrollbars="vertical"
        android:fadeScrollbars="false"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/temperatureLayout"
                android:layout_width="match_parent"
                android:layout_height="@dimen/_90sdp"
                android:layout_margin="@dimen/_5sdp"
                android:background="@drawable/gradient_bg"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginStart="24dp"
                    android:layout_weight="4"
                    android:gravity="center_vertical"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/timestamp_textView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="@color/white"
                        android:textSize="@dimen/_11sdp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/temperatureTextView"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textColor="@color/white"
                            android:textSize="@dimen/_18sdp"
                            android:textStyle="bold"
                            android:visibility="visible" />

                        <ProgressBar
                            android:id="@+id/progressBar"
                            style="?android:attr/progressBarStyle"
                            android:layout_width="@dimen/_20sdp"
                            android:layout_height="@dimen/_20sdp"
                            android:gravity="start"
                            android:indeterminateTint="@android:color/white"
                            android:indeterminateTintMode="src_in"
                            android:visibility="visible" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/weatherTalukaTV"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="@color/white"
                        android:textSize="@dimen/_12sdp" />

                </LinearLayout>

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical"
                    android:layout_weight="6"
                    app:srcCompat="@drawable/weather_icon_figma" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/AddCrop"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    tools:layout_editor_absoluteX="1dp"
                    tools:layout_editor_absoluteY="235dp">

                    <LinearLayout
                        android:id="@+id/etlWarningLayout"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/_20sdp"
                        android:background="@color/yeellowies"
                        android:orientation="horizontal"
                        android:visibility="gone">

                        <ImageView
                            android:id="@+id/imageView14"
                            android:layout_width="@dimen/_20sdp"
                            android:layout_height="match_parent"
                            android:layout_marginStart="@dimen/_10sdp"
                            app:srcCompat="@drawable/ic_warning" />

                        <TextView
                            android:id="@+id/textView2"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:layout_marginStart="@dimen/_5sdp"
                            android:gravity="center_vertical"
                            android:text="@string/etl_crossed_click_here_for_advisory"
                            android:textColor="@color/red" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/greetingsTextView"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:layout_marginStart="@dimen/_10sdp"
                            android:gravity="center_vertical"
                            android:text="Good Morning,"
                            android:textSize="@dimen/_12sdp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/userFullNameTextView"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_marginStart="@dimen/_5sdp"
                            android:layout_weight="4"
                            android:ellipsize="end"
                            android:gravity="center_vertical"
                            android:maxLines="1"
                            android:singleLine="true"
                            android:text=""
                            android:textSize="@dimen/_12sdp" />

                        <LinearLayout
                            android:id="@+id/krishiTaiLayout"
                            android:layout_width="@dimen/_80sdp"
                            android:layout_height="wrap_content"
                            android:layout_marginRight="@dimen/_10sdp"
                            android:background="@drawable/bg_krishi_button"
                            android:gravity="center"
                            android:orientation="horizontal"
                            android:paddingVertical="@dimen/_4sdp"
                            android:visibility="gone">

                            <TextView
                                android:id="@+id/smaRedirectTextView"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginRight="@dimen/_5sdp"
                                android:text="@string/KrishiTai"
                                android:textColor="@android:color/white"
                                android:textSize="@dimen/_10sdp"
                                android:textStyle="bold" />

                            <ImageView
                                android:id="@+id/arrowIcon"
                                android:layout_width="@dimen/_10sdp"
                                android:layout_height="@dimen/_10sdp"
                                android:padding="@dimen/_2sdp"
                                android:src="@drawable/navigating_arrow" />
                        </LinearLayout>

                    </LinearLayout>

                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/_60sdp"
                        android:layout_marginHorizontal="@dimen/_10sdp"
                        android:layout_marginVertical="@dimen/_5sdp"
                        android:backgroundTint="@color/card_background_color_figma_dash"
                        app:cardCornerRadius="@dimen/_15sdp"
                        app:cardElevation="@dimen/_1sdp"
                        app:useCompatPadding="false">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="@dimen/_85sdp"
                                android:layout_weight="1"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <TextView
                                    android:id="@+id/yourCropTv"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_gravity="center_vertical"
                                    android:layout_weight="1"
                                    android:paddingStart="@dimen/_10sdp"
                                    android:text="@string/no_crops_added"
                                    android:textSize="@dimen/_10sdp"
                                    android:visibility="visible" />

                                <LinearLayout
                                    android:id="@+id/savedCropNameCardView"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="@dimen/_10sdp"
                                    android:layout_marginEnd="@dimen/_10sdp"
                                    android:gravity="center_vertical"
                                    android:orientation="horizontal"
                                    android:paddingVertical="@dimen/_6sdp"
                                    android:visibility="gone"> <!-- Optional background -->

                                    <!-- Image with circular background -->
                                    <FrameLayout
                                        android:layout_width="@dimen/_38sdp"
                                        android:layout_height="@dimen/_38sdp"
                                        android:background="@drawable/shape_round_gray">

                                        <de.hdodenhof.circleimageview.CircleImageView
                                            android:id="@+id/savedCropNameImageView"
                                            android:layout_width="match_parent"
                                            android:layout_height="match_parent"
                                            android:scaleType="centerCrop"
                                            android:src="@drawable/trigo"
                                            app:civ_border_color="#CBD5E1"
                                            app:civ_border_width="@dimen/_1sdp" />
                                    </FrameLayout>

                                    <!-- Crop name with wrapping text -->
                                    <TextView
                                        android:id="@+id/savedCropNameTextView"
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_marginStart="@dimen/_8sdp"
                                        android:layout_marginEnd="@dimen/_8sdp"
                                        android:layout_weight="1"
                                        android:ellipsize="end"
                                        android:maxLines="2"
                                        android:text="Crop Name"
                                        android:textColor="@color/font_color_figma"
                                        android:textSize="@dimen/_10sdp"
                                        android:textStyle="bold" />

                                    <!-- Change button -->
                                    <TextView
                                        android:id="@+id/changeCropText"
                                        android:layout_width="@dimen/_60sdp"
                                        android:layout_height="wrap_content"
                                        android:layout_marginEnd="@dimen/_4sdp"
                                        android:background="@drawable/background_for_chat_request_green"
                                        android:gravity="center"
                                        android:paddingVertical="@dimen/_6sdp"
                                        android:text="@string/change"
                                        android:textColor="@color/white"
                                        android:textSize="@dimen/_10sdp" />

                                    <!-- Delete button -->
                                    <TextView
                                        android:id="@+id/deleteCropImageView"
                                        android:layout_width="@dimen/_60sdp"
                                        android:layout_height="wrap_content"
                                        android:layout_marginEnd="@dimen/_4sdp"
                                        android:background="@drawable/background_for_delete_request"
                                        android:gravity="center"
                                        android:paddingVertical="@dimen/_6sdp"
                                        android:text="@string/delete"
                                        android:textColor="@color/red"
                                        android:textSize="@dimen/_10sdp" />

                                </LinearLayout>


                                <androidx.cardview.widget.CardView
                                    android:id="@+id/addCropCardView"
                                    android:layout_width="match_parent"
                                    android:layout_height="@dimen/_40sdp"
                                    android:layout_gravity="center_vertical"
                                    android:layout_marginVertical="@dimen/_2sdp"
                                    android:layout_marginEnd="@dimen/_5sdp"
                                    android:layout_weight="1"
                                    android:visibility="visible"
                                    app:cardCornerRadius="@dimen/_25sdp">

                                    <LinearLayout
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        android:layout_marginStart="@dimen/_10sdp"
                                        android:gravity="center_vertical"
                                        android:orientation="horizontal">

                                        <androidx.constraintlayout.widget.ConstraintLayout
                                            android:layout_width="@dimen/_30sdp"
                                            android:layout_height="@dimen/_30sdp"
                                            android:background="@drawable/shape_round_gray">

                                            <ImageView
                                                android:layout_width="@dimen/_30sdp"
                                                android:layout_height="@dimen/_30sdp"
                                                android:padding="@dimen/_8sdp"
                                                android:src="@drawable/trigo"
                                                app:layout_constraintBottom_toBottomOf="parent"
                                                app:layout_constraintEnd_toEndOf="parent"
                                                app:layout_constraintStart_toStartOf="parent"
                                                app:layout_constraintTop_toTopOf="parent" />
                                        </androidx.constraintlayout.widget.ConstraintLayout>


                                        <TextView
                                            android:id="@+id/addChangeCropTV"
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content"
                                            android:layout_marginStart="@dimen/_6sdp"
                                            android:layout_weight="1"
                                            android:text="@string/add_Crop"
                                            android:textColor="@color/font_color_figma"
                                            android:textSize="@dimen/_10sdp"
                                            android:textStyle="bold" />

                                        <ImageView
                                            android:id="@+id/addChangeCropIV"
                                            android:layout_width="@dimen/_20sdp"
                                            android:layout_height="@dimen/_20sdp"
                                            android:layout_marginEnd="@dimen/_10sdp"
                                            android:padding="@dimen/_2sdp"
                                            app:srcCompat="@drawable/baseline_add_24"
                                            app:tint="@color/arrow_color_figma" />

                                    </LinearLayout>
                                </androidx.cardview.widget.CardView>

                            </LinearLayout>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                </LinearLayout>

            </LinearLayout>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="@dimen/_130sdp"
                app:cardCornerRadius="@dimen/_15sdp"
                android:backgroundTint="@color/pale_aqua"
                android:layout_marginBottom="@dimen/_10sdp"
                android:layout_marginHorizontal="@dimen/_10sdp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginHorizontal="@dimen/_10sdp"
                    android:layout_marginBottom="@dimen/_5sdp"
                    android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/imageView32"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_weight="3" >

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:padding="@dimen/_15sdp"
                                android:layout_weight="3"
                                app:srcCompat="@drawable/pnd_img_one" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:textStyle="bold"
                                android:textSize="@dimen/_10sdp"
                                android:textColor="@color/font_color_figma"
                                android:text="@string/take_a_npicture" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="@dimen/_20sdp"
                            android:layout_height="match_parent"
                            android:orientation="vertical">

                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:padding="@dimen/_4sdp"
                                android:layout_weight="3"
                                app:srcCompat="@drawable/pnd_img_nav" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:layout_weight="7"
                                android:gravity="center"
                                android:textColor="@color/black"
                                android:textStyle="bold"
                                android:textSize="@dimen/_10sdp"
                                android:text="" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:layout_weight="3"
                                android:padding="@dimen/_15sdp"
                                app:srcCompat="@drawable/pnd_img_two" />
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:textSize="@dimen/_10sdp"
                                android:textColor="@color/font_color_figma"
                                android:textStyle="bold"
                                android:text="@string/get_ndiagnosis" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="@dimen/_20sdp"
                            android:layout_height="match_parent"
                            android:orientation="vertical">

                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:padding="@dimen/_4sdp"
                                android:layout_weight="3"
                                app:srcCompat="@drawable/pnd_img_nav" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:layout_weight="7"
                                android:gravity="center"
                                android:textColor="@color/black"
                                android:textStyle="bold"
                                android:textSize="@dimen/_10sdp"
                                android:text="" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:layout_weight="3"
                                android:padding="@dimen/_15sdp"
                                app:srcCompat="@drawable/pnd_img_three" />
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:textSize="@dimen/_10sdp"
                                android:textColor="@color/font_color_figma"
                                android:textStyle="bold"
                                android:text="@string/get_the_nresult" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/takePictureButton"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_weight="7"
                        android:layout_marginTop="@dimen/_4sdp"
                        android:textAllCaps="false"
                        android:gravity="center"
                        android:background="@drawable/scan_image_button_drawable"
                        android:text="Take a Picture">

                        <ImageView
                            android:id="@+id/imageView35"
                            android:layout_width="@dimen/_15sdp"
                            android:layout_height="@dimen/_15sdp"
                            android:layout_gravity="center_vertical"
                            app:srcCompat="@drawable/pnd_camera" />

                        <TextView
                            android:id="@+id/textView41"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/white"
                            android:textSize="@dimen/_10sdp"
                            android:layout_gravity="center_vertical"
                            android:layout_marginStart="@dimen/_10sdp"
                            android:text="@string/identity_pest_amp_disease" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/dashboardRecyclerView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:paddingHorizontal="10dp"/>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>


    <ImageView
        android:id="@+id/chatbotIcon"
        android:layout_width="@dimen/_50sdp"
        android:layout_height="@dimen/_50sdp"
        android:layout_marginBottom="@dimen/_20sdp"
        app:layout_constraintBottom_toBottomOf="@+id/linearLayout13"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@+id/linearLayout13"
        app:srcCompat="@drawable/chatbot_icon" />

    <ImageView
        android:id="@+id/chatBubbleImageView"
        android:layout_width="@dimen/_60sdp"
        android:layout_height="@dimen/_60sdp"
        android:layout_marginBottom="@dimen/_40sdp"
        app:layout_constraintBottom_toBottomOf="@+id/chatbotIcon"
        app:layout_constraintEnd_toEndOf="@+id/chatbotIcon"
        app:layout_constraintStart_toStartOf="@+id/chatbotIcon"
        app:srcCompat="@drawable/center_bubble" />

    <LinearLayout
        android:id="@+id/linearLayout13"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <include
            android:id="@+id/customNavBottom"
            layout="@layout/custom_bottom_nav" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
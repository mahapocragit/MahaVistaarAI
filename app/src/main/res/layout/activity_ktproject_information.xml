<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".sma.ui.screens.KTProjectInformation">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar2"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorPrimary"
        app:title="@string/work_activity"
        app:titleTextAppearance="@style/ToolbarTitleStyle"
        app:titleTextColor="@android:color/white"
        app:navigationIcon="@drawable/ic_arrow_left_back_24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@+id/toolbar2"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:dividerHeight="12dp">

            <!-- Item 1 -->
            <LinearLayout
                android:id="@+id/itemDocuments"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/btn_proj_info"
                android:padding="6dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="१. प्रकल्प माहिती पुस्तिका"
                    android:textSize="18sp"
                    android:paddingStart="12dp"
                    android:textStyle="bold"
                    android:textColor="@color/black"
                    android:layout_weight="1"/>
                <ImageView
                    android:layout_width="75dp"
                    android:layout_height="55dp"
                    android:background="@color/white"
                    android:padding="2dp"
                    android:src="@drawable/ic_view_link" />

            </LinearLayout>

            <!-- Item 2 -->
            <LinearLayout
                android:id="@+id/itemGuidelines"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/btn_proj_info"
                android:padding="6dp"
                android:layout_marginTop="5dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="२. प्रकल्पाच्या मार्गदर्शक सूचना"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:paddingStart="12dp"
                    android:textColor="@color/black"
                    android:layout_weight="1"/>
                <ImageView
                    android:layout_width="75dp"
                    android:layout_height="55dp"
                    android:background="@color/white"
                    android:padding="2dp"
                    android:src="@drawable/ic_view_link" />

            </LinearLayout>

            <!-- Item 3 -->
            <LinearLayout
                android:id="@+id/itemMahavistar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="5dp"
                android:elevation="8dp"
                android:background="@drawable/btn_proj_info"
                android:padding="6dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="३. महाविस्तार-एआय "
                    android:textSize="18sp"
                    android:paddingStart="12dp"
                    android:textStyle="bold"
                    android:textColor="@color/black"
                    android:layout_weight="1"/>
                <ImageView
                    android:layout_width="75dp"
                    android:layout_height="55dp"
                    android:background="@color/white"
                    android:padding="2dp"
                    android:src="@drawable/ic_view_link" />

            </LinearLayout>
            <LinearLayout
                android:id="@+id/itemVideos"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="5dp"
                android:elevation="8dp"
                android:background="@drawable/btn_proj_info"
                android:padding="6dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="४. प्रकल्पाचे विविध व्हिडिओ"
                    android:textSize="18sp"
                    android:paddingStart="12dp"
                    android:textStyle="bold"
                    android:textColor="@color/black"
                    android:layout_weight="1"/>
                <ImageView
                    android:layout_width="75dp"
                    android:layout_height="55dp"
                    android:background="@color/white"
                    android:padding="2dp"
                    android:src="@drawable/play_video_img" />

            </LinearLayout>


        </LinearLayout>

    </ScrollView>


</RelativeLayout>
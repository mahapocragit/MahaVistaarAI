<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/status_colored_background"
    tools:context=".ui.screens.dashboard.menugrid.marketprice.MarketPrice">

    <LinearLayout
        android:id="@+id/linearLayout12"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <include
            android:id="@+id/relativeLayoutTopBar"
            layout="@layout/layout_toolbar" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/_10sdp"
            android:backgroundTint="@color/card_background_color_figma"
            app:cardCornerRadius="@dimen/_5sdp">

            <TextView
                android:id="@+id/tv_source_information"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:paddingHorizontal="@dimen/_4sdp"
                android:paddingVertical="@dimen/_8sdp"
                android:text="@string/source_info_market"
                android:textColor="@color/gray_light"
                android:textSize="@dimen/text16"
                android:visibility="visible" />
        </androidx.cardview.widget.CardView>

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/_34sdp"
            android:layout_marginTop="@dimen/height10"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/textViewDistrict"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginStart="@dimen/padding20"
                android:layout_marginEnd="@dimen/padding20"
                android:background="@drawable/layout_warehouse_dropdown"
                android:gravity="start|center_vertical"
                android:hint="@string/farmer_select_district"
                android:paddingStart="@dimen/padding20"
                android:paddingEnd="@dimen/padding20"
                android:text="@string/farmer_select_district"
                android:textColor="@color/heading"
                android:textSize="@dimen/text14"
                android:textStyle="normal" />

            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_alignParentRight="true"
                android:layout_centerVertical="true"
                android:layout_marginEnd="@dimen/padding30"
                android:layout_marginRight="@dimen/padding30"
                android:contentDescription="@string/app_name"
                app:srcCompat="@drawable/ic_baseline_arrow_drop_down_24"
                tools:ignore="VectorDrawableCompat" />
        </RelativeLayout>

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/_36sdp"
            android:layout_marginTop="@dimen/height10"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/textViewMarket"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginStart="@dimen/padding20"
                android:layout_marginEnd="@dimen/padding20"
                android:background="@drawable/layout_warehouse_dropdown"
                android:gravity="start|center_vertical"
                android:hint="@string/farmer_select_market"
                android:paddingStart="@dimen/padding20"
                android:paddingEnd="@dimen/padding20"
                android:text="@string/farmer_select_market"
                android:textColor="@color/heading"
                android:textSize="@dimen/text14"
                android:textStyle="normal" />

            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_alignParentRight="true"
                android:layout_centerVertical="true"
                android:layout_marginEnd="@dimen/padding30"
                android:layout_marginRight="@dimen/padding30"
                android:contentDescription="@string/app_name"
                app:srcCompat="@drawable/ic_baseline_arrow_drop_down_24"
                tools:ignore="VectorDrawableCompat" />

        </RelativeLayout>

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/_36sdp"
            android:layout_marginTop="@dimen/height10"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/searchEditText"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginStart="@dimen/padding20"
                android:layout_marginEnd="@dimen/padding20"
                android:background="@drawable/layout_warehouse_dropdown"
                android:gravity="center_vertical"
                android:hint="@string/search_by_crop_name"
                android:inputType="text"
                android:paddingStart="@dimen/padding20"
                android:paddingEnd="@dimen/padding20"
                android:textSize="@dimen/text14" />

            <ImageView
                android:layout_width="@dimen/_20sdp"
                android:layout_height="@dimen/_20sdp"
                android:layout_alignParentEnd="true"
                android:layout_alignParentRight="true"
                android:layout_centerVertical="true"
                android:layout_marginEnd="@dimen/padding30"
                android:layout_marginRight="@dimen/padding30"
                android:contentDescription="@string/app_name"
                android:padding="@dimen/_2sdp"
                app:srcCompat="@drawable/search"
                tools:ignore="VectorDrawableCompat" />

        </RelativeLayout>

        <RelativeLayout
            android:id="@+id/calenderLayout"
            android:layout_width="match_parent"
            android:layout_height="@dimen/_36sdp"
            android:layout_marginTop="@dimen/height10"
            android:orientation="horizontal"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvMarketDate"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginStart="@dimen/padding20"
                android:layout_marginEnd="@dimen/padding20"
                android:background="@drawable/layout_warehouse_dropdown"
                android:gravity="start|center_vertical"
                android:hint="@string/date_text"
                android:paddingStart="@dimen/padding20"
                android:paddingEnd="@dimen/padding20"
                android:textColor="@color/heading"
                android:textSize="@dimen/text14"
                android:textStyle="normal" />

            <ImageView
                android:layout_width="45dp"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_alignParentRight="true"
                android:layout_centerVertical="true"
                android:layout_marginEnd="@dimen/padding30"
                android:layout_marginRight="@dimen/padding30"
                android:contentDescription="@string/app_name"
                android:padding="5dp"
                app:srcCompat="@mipmap/ic_calendar"
                tools:ignore="VectorDrawableCompat" />

        </RelativeLayout>

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/_10sdp"
            android:layout_marginTop="@dimen/height10"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_market_details"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="20dp"
                android:layout_marginRight="20dp"
                android:gravity="center"
                android:textColor="@color/font_color_figma"
                android:textSize="@dimen/text16"
                android:textStyle="bold"
                android:visibility="invisible" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerViewMarketPriceList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@+id/tv_market_details"
                android:layout_marginTop="5dp"
                android:padding="@dimen/height5" />

        </RelativeLayout>
    </LinearLayout>

    <ImageView
        android:id="@+id/chatbotIcon"
        android:layout_width="@dimen/_58sdp"
        android:layout_height="@dimen/_58sdp"
        android:layout_margin="@dimen/_10sdp"
        android:padding="@dimen/_5sdp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:srcCompat="@drawable/chatbot_icon" />

    <ImageView
        android:id="@+id/bubbleIconImageView"
        android:layout_width="@dimen/_60sdp"
        android:layout_height="@dimen/_60sdp"
        android:layout_margin="@dimen/_25sdp"
        app:layout_constraintBottom_toBottomOf="@+id/chatbotIcon"
        app:layout_constraintEnd_toEndOf="@+id/chatbotIcon"
        app:srcCompat="@drawable/corner_bubble" />


</androidx.constraintlayout.widget.ConstraintLayout>
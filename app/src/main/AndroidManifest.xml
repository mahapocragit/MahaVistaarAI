        <activity android:name=".ui.screens.authentication.PreRegistrationActivity" />
        <activity android:name=".ui.screens.dashboard.menugrid.dbt.DBTDashboard" />
        <activity android:name=".ui.screens.dashboard.sidenavigation.leaderboard.LeaderboardActivity" />
        <activity android:name=".ui.screens.dashboard.sidenavigation.experts.ExpertsCornerFilterActivity" />
        <activity android:name=".ui.screens.dashboard.sidenavigation.costcalculator.CropCostCalculationActivity" />
        <activity android:name=".ui.screens.dashboard.sidenavigation.costcalculator.CostCalculatorDashboardActivity" />
        <activity android:name=".ui.screens.dashboard.sidenavigation.experts.ExpertsCornerFarmerActivity" />
        <activity android:name=".ui.screens.dashboard.sidenavigation.experts.ExpertsCornerAdminActivity" />
        <activity android:name=".ui.screens.notification.DetailedNotificationActivity" />
        <activity android:name=".ui.screens.dashboard.etl.AgriStackAdvisoryActivity" />
